---
interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  label: string;
  items: BreadcrumbItem[];
}

const { label, items } = Astro.props;
---

<nav class="breadcrumbs" aria-label={label}>
  <ol>
    {items.map((item, index) => (
      <li>
        {item.href ? <a href={item.href}>{item.label}</a> : <span aria-current="page">{item.label}</span>}
        {index < items.length - 1 && <span class="breadcrumbs__separator" aria-hidden="true">/</span>}
      </li>
    ))}
  </ol>
</nav>

<style>
  .breadcrumbs { color: var(--color-deep-herb); font-size: var(--text-xs); letter-spacing: 0.04em; text-transform: uppercase; }
  .breadcrumbs ol { display: flex; flex-wrap: wrap; gap: var(--space-2); list-style: none; }
  .breadcrumbs li { align-items: center; display: flex; gap: var(--space-2); }
  .breadcrumbs a { color: inherit; }
  .breadcrumbs__separator { color: var(--color-paradise-orange); }
</style>
