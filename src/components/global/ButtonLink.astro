---
interface Props {
  href: string;
  variant?: 'primary' | 'secondary';
  class?: string;
}

import Icon from './Icon.astro';

const { href, variant = 'primary', class: className } = Astro.props;
---

<a class:list={['button-link', `button-link--${variant}`, className]} href={href}>
  <slot />
  <Icon name="lucide:arrow-up-right" size="1.05em" />
</a>

<style>
  .button-link {
    align-items: center;
    border: 1px solid var(--color-graphite);
    border-radius: var(--radius-sm);
    display: inline-flex;
    font-size: var(--text-sm);
    font-weight: 600;
    gap: var(--space-5);
    justify-content: space-between;
    min-block-size: 2.75rem;
    padding: var(--space-3) var(--space-4);
    text-decoration: none;
    transition: background-color var(--transition-fast), border-color var(--transition-fast), color var(--transition-fast);
  }

  .button-link--primary {
    background: var(--color-graphite);
    border-color: var(--color-paradise-orange);
    color: var(--color-process-white);
  }

  .button-link--primary:hover {
    background: var(--color-graphite);
    border-color: var(--color-paradise-orange);
    color: var(--color-process-white);
  }

  .button-link--secondary {
    background: var(--color-process-white);
    border-color: var(--color-graphite);
    color: var(--color-graphite);
  }

  .button-link--secondary:hover {
    background: var(--color-cold-paper);
  }
</style>
