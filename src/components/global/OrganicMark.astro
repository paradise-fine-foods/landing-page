---
interface Props {
  variant: 'drop' | 'seed' | 'petal';
  color: 'orange' | 'blue' | 'green' | 'coral';
  class?: string;
}

const { variant, color, class: className } = Astro.props;

const paths: Record<Props['variant'], string> = {
  drop: 'M12 1.5C8.5 6.1 4 10.4 4 15.2A8 8 0 0 0 20 15.2C20 10.4 15.5 6.1 12 1.5Z',
  seed: 'M20.5 3.5C11.6 3.7 4.2 8.2 3.5 17.8C12.5 20.4 20.1 13.8 20.5 3.5Z',
  petal: 'M12 2C16.8 5.7 20 10.2 20 14.4C20 18.3 16.7 21 12 21C7.3 21 4 18.3 4 14.4C4 10.2 7.2 5.7 12 2Z',
};
---

<svg
  class:list={['organic-mark', `organic-mark--${color}`, className]}
  viewBox="0 0 24 24"
  aria-hidden="true"
  focusable="false"
>
  <path d={paths[variant]} />
</svg>

<style>
  .organic-mark { fill: currentColor; }
  .organic-mark--orange { color: var(--color-paradise-orange); }
  .organic-mark--blue { color: var(--color-paradise-blue); }
  .organic-mark--green { color: var(--color-paradise-green); }
  .organic-mark--coral { color: var(--color-paradise-coral); }
</style>
