---
import type { Locale } from '../../lib/i18n/types';
import type { UiCopy } from '../../lib/i18n/ui';

interface Props {
  locale: Locale;
  contactPath: string;
  copy: UiCopy['floatingRail'];
  staticOnly?: boolean;
}

const { locale, contactPath, copy, staticOnly = false } = Astro.props;
---

<div class="floating-form-rail" data-floating-rail data-locale={locale}>
  <button
    class="floating-form-rail__toggle"
    type="button"
    aria-controls="floating-rail-panel"
    aria-expanded="false"
    aria-label={copy.toggleOpen}
    data-floating-rail-toggle
    data-open-label={copy.toggleOpen}
    data-close-label={copy.toggleClose}
  >
    <span class="floating-form-rail__label" data-floating-rail-label aria-hidden="true">{copy.label}</span>
    <span class="floating-form-rail__toggle-icon" aria-hidden="true">+</span>
  </button>
  <nav id="floating-rail-panel" class="floating-form-rail__panel" aria-label={copy.navigation}>
    <span class="floating-form-rail__marker" aria-hidden="true"></span>
    <div class="floating-form-rail__heading" data-floating-rail-title>{copy.panelTitle}</div>
    <a href={`${contactPath}?interest=retail`}>{copy.buy}</a>
    <a href={`${contactPath}?interest=other`}>{copy.sell}</a>
    <a href={contactPath}>{copy.contact}</a>
  </nav>
</div>

{!staticOnly && <script>
  import { initializeFloatingRail } from '../../lib/motion/floating-rail';

  const rail = document.querySelector<HTMLElement>('[data-floating-rail]');
  if (rail) initializeFloatingRail(rail);
</script>}

<style>
  .floating-form-rail {
    align-items: flex-end;
    display: flex;
    flex-direction: row-reverse;
    gap: 0.75rem;
    inset-inline-end: 1rem;
    position: fixed;
    top: 50%;
    transform: translateY(-50%);
    transition: opacity 180ms ease, visibility 180ms ease;
    z-index: 15;
  }

  .floating-form-rail[data-ready='true'] {
    opacity: 0;
    pointer-events: none;
    visibility: hidden;
  }

  .floating-form-rail[data-ready='true'][data-visible='true'] {
    opacity: 1;
    pointer-events: auto;
    visibility: visible;
  }

  .floating-form-rail__toggle,
  .floating-form-rail__panel a {
    align-items: center;
    display: flex;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 700;
    justify-content: center;
    min-block-size: 2.75rem;
    text-decoration: none;
  }

  .floating-form-rail__toggle { display: none; }
  .floating-form-rail[data-ready='true'] .floating-form-rail__toggle { display: flex; }
  .floating-form-rail[data-ready='true'][data-expanded='false'] .floating-form-rail__panel { display: none; }

  .floating-form-rail__toggle {
    align-items: center;
    background: var(--color-deep-herb);
    border: 0;
    border-inline-start: 0.25rem solid var(--color-paradise-orange);
    color: var(--color-rice-paper);
    cursor: pointer;
    flex-direction: column;
    gap: 0.5rem;
    inline-size: 4.25rem;
    justify-content: center;
    min-block-size: 5.75rem;
    padding: 0.75rem 0.5rem;
    transition: background-color 180ms ease, color 180ms ease, transform 180ms ease;
  }

  .floating-form-rail__toggle:hover,
  .floating-form-rail__toggle:focus-visible {
    background: var(--color-paradise-orange);
    color: var(--color-paper-white);
  }

  .floating-form-rail__label {
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    line-height: 1;
    writing-mode: vertical-rl;
    transform: rotate(180deg);
  }

  .floating-form-rail__toggle-icon {
    font-size: var(--text-xl);
    font-weight: 400;
    line-height: 1;
  }

  .floating-form-rail__panel {
    background: var(--color-paper-white);
    border-block-start: 0.25rem solid var(--color-paradise-orange);
    clip-path: polygon(0 0, 100% 0, 100% calc(100% - 1rem), calc(100% - 1rem) 100%, 0 100%);
    display: grid;
    gap: 0;
    min-inline-size: min(19rem, calc(100vw - 2rem));
    padding: 1rem 1rem 0.875rem;
    transition: opacity 180ms ease, transform 180ms ease;
  }

  .floating-form-rail__marker {
    background: var(--color-paradise-orange);
    block-size: 0.25rem;
    display: block;
    inline-size: 2rem;
    margin-block-end: 0.75rem;
  }

  .floating-form-rail__heading {
    color: var(--color-deep-herb);
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 500;
    line-height: var(--leading-heading);
    padding-block-end: 0.625rem;
  }

  .floating-form-rail__panel a {
    background: transparent;
    border-block-start: 1px solid color-mix(in srgb, var(--color-deep-herb) 18%, transparent);
    color: var(--color-deep-herb);
    justify-content: space-between;
    min-block-size: 3rem;
    padding-inline: 0.25rem;
    transition: background-color 180ms ease, color 180ms ease;
  }

  .floating-form-rail__panel a::after {
    color: var(--color-paradise-orange);
    content: '↗';
    font-size: var(--text-lg);
    font-weight: 400;
    margin-inline-start: 1rem;
  }

  .floating-form-rail__panel a:hover,
  .floating-form-rail__panel a:focus-visible {
    background: var(--color-mist-blue);
    color: var(--color-deep-herb);
  }

  @media (max-width: 48rem) {
    .floating-form-rail {
      align-items: flex-end;
      flex-direction: column-reverse;
      inset-block-end: 1rem;
      inset-inline: 1rem;
      max-inline-size: min(20rem, calc(100vw - 2rem));
      top: auto;
      transform: none;
    }

    .floating-form-rail__panel {
      min-inline-size: 0;
      inline-size: 100%;
    }

    .floating-form-rail__toggle {
      flex-direction: row;
      inline-size: auto;
      min-block-size: 3.25rem;
      min-inline-size: 7rem;
    }

    .floating-form-rail__label {
      writing-mode: horizontal-tb;
      transform: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .floating-form-rail,
    .floating-form-rail__panel,
    .floating-form-rail__toggle,
    .floating-form-rail__panel a {
      transition: none;
    }
  }
</style>
