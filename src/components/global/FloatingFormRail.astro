---
import type { Locale } from '../../lib/i18n/types';
import type { UiCopy } from '../../lib/i18n/ui';

interface Props {
  locale: Locale;
  contactPath: string;
  copy: UiCopy['floatingRail'];
}

const { locale, contactPath, copy } = Astro.props;
---

<div class="floating-form-rail" data-floating-rail data-locale={locale}>
  <button
    class="floating-form-rail__toggle"
    type="button"
    aria-controls="floating-rail-panel"
    aria-expanded="false"
    aria-label={copy.toggleOpen}
    data-floating-rail-toggle
    data-open-label={copy.toggleOpen}
    data-close-label={copy.toggleClose}
  >
    <span aria-hidden="true">+</span>
  </button>
  <nav id="floating-rail-panel" class="floating-form-rail__panel" aria-label={copy.navigation}>
    <a href={`${contactPath}?interest=retail`}>{copy.buy}</a>
    <a href={`${contactPath}?interest=other`}>{copy.sell}</a>
    <a href={contactPath}>{copy.contact}</a>
  </nav>
</div>

<script>
  import { initializeFloatingRail } from '../../lib/motion/floating-rail';

  const rail = document.querySelector<HTMLElement>('[data-floating-rail]');
  if (rail) initializeFloatingRail(rail);
</script>

<style>
  .floating-form-rail {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    inset-inline-end: 1rem;
    position: fixed;
    top: 50%;
    transform: translateY(-50%);
    transition: opacity 180ms ease, visibility 180ms ease;
    z-index: 15;
  }

  .floating-form-rail[data-ready='true'] {
    opacity: 0;
    pointer-events: none;
    visibility: hidden;
  }

  .floating-form-rail[data-ready='true'][data-visible='true'] {
    opacity: 1;
    pointer-events: auto;
    visibility: visible;
  }

  .floating-form-rail__toggle,
  .floating-form-rail__panel a {
    align-items: center;
    background: var(--color-deep-herb);
    border: 1px solid var(--color-deep-herb);
    color: var(--color-rice-paper);
    display: flex;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 700;
    justify-content: center;
    min-block-size: 2.75rem;
    text-decoration: none;
  }

  .floating-form-rail__toggle {
    cursor: pointer;
    inline-size: 2.75rem;
    padding: 0;
  }

  .floating-form-rail__toggle:hover,
  .floating-form-rail__toggle:focus-visible,
  .floating-form-rail__panel a:hover,
  .floating-form-rail__panel a:focus-visible {
    background: var(--color-paradise-blue);
    border-color: var(--color-paradise-blue);
  }

  .floating-form-rail__panel {
    display: grid;
    gap: 1px;
    transition: opacity 180ms ease;
  }

  .floating-form-rail__panel a {
    min-inline-size: 10rem;
    padding-inline: 1rem;
  }

  @media (max-width: 48rem) {
    .floating-form-rail {
      align-items: stretch;
      flex-direction: row;
      inset-block-end: 1rem;
      inset-inline: 1rem;
      top: auto;
      transform: none;
    }

    .floating-form-rail__panel {
      flex: 1;
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .floating-form-rail[data-ready='true'][data-expanded='false'] .floating-form-rail__panel {
      display: none;
    }

    .floating-form-rail__panel a {
      min-inline-size: 0;
      padding-inline: 0.5rem;
      text-align: center;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .floating-form-rail,
    .floating-form-rail__panel {
      transition: none;
    }
  }
</style>
