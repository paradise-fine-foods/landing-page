---
import type { Locale } from '../../lib/i18n/types';
import type { UiCopy } from '../../lib/i18n/ui';
import Icon from './Icon.astro';

interface Props {
  locale: Locale;
  contactPath: string;
  customerPath: string;
  supplierPath: string;
  copy: UiCopy['floatingRail'];
  staticOnly?: boolean;
}

const { locale, contactPath, customerPath, supplierPath, copy, staticOnly = false } = Astro.props;
---

<div class="floating-form-rail" data-floating-rail data-locale={locale}>
  <button
    class="floating-form-rail__toggle"
    type="button"
    aria-controls="floating-rail-panel"
    aria-expanded="false"
    aria-label={copy.toggleOpen}
    data-floating-rail-toggle
    data-open-label={copy.toggleOpen}
    data-close-label={copy.toggleClose}
  >
    <span class="floating-form-rail__toggle-icon floating-form-rail__toggle-icon--collapsed" data-floating-rail-icon aria-hidden="true"><Icon name="lucide:chevron-left" size="1.15em" /></span>
    <span class="floating-form-rail__toggle-icon floating-form-rail__toggle-icon--expanded" data-floating-rail-icon aria-hidden="true"><Icon name="lucide:chevron-right" size="1.15em" /></span>
  </button>
  <nav id="floating-rail-panel" class="floating-form-rail__panel" aria-label={copy.navigation}>
    <a href={customerPath}>{copy.buy}<Icon name="lucide:arrow-up-right" size="1em" /></a>
    <a href={supplierPath}>{copy.sell}<Icon name="lucide:arrow-up-right" size="1em" /></a>
    <a href={contactPath}>{copy.contact}<Icon name="lucide:arrow-up-right" size="1em" /></a>
  </nav>
</div>

{!staticOnly && <script>
  import { initializeFloatingRail } from '../../lib/motion/floating-rail';

  const rail = document.querySelector<HTMLElement>('[data-floating-rail]');
  if (rail) initializeFloatingRail(rail);
</script>}

<style>
  .floating-form-rail {
    align-items: flex-start;
    display: flex;
    flex-direction: row;
    inset-inline-end: 0;
    pointer-events: none;
    position: fixed;
    top: calc(5rem + var(--space-6));
    transform: none;
    translate: 0 0;
    filter: none;
    transition: translate var(--transition-base);
    z-index: 15;
  }

  .floating-form-rail:not([data-ready]) {
    align-items: stretch;
    background: var(--color-cold-paper);
    border-block-start: 1px solid var(--color-brushed-steel);
    inset: auto;
    inline-size: 100%;
    margin-inline: auto;
    max-inline-size: var(--container-max);
    padding: var(--space-4) var(--container-inline);
    pointer-events: auto;
    position: static;
    transform: none;
    translate: none;
    z-index: auto;
  }

  .floating-form-rail:not([data-ready]) .floating-form-rail__toggle { display: none; }

  .floating-form-rail:not([data-ready]) .floating-form-rail__panel {
    inline-size: 100%;
    max-inline-size: none;
  }

  .floating-form-rail[data-ready='true'][data-expanded='false'] {
    translate: calc(100% - 2.75rem) 0;
  }

  .floating-form-rail__toggle,
  .floating-form-rail__panel a {
    align-items: center;
    display: flex;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 700;
    text-decoration: none;
  }

  .floating-form-rail__toggle {
    background: var(--color-graphite);
    border: 0;
    border-inline-start: 2px solid var(--color-paradise-orange);
    color: var(--color-process-white);
    cursor: pointer;
    display: none;
    block-size: 2.75rem;
    inline-size: 2.75rem;
    justify-content: center;
    padding: 0;
    pointer-events: auto;
    filter: none;
    transition: background-color var(--transition-fast);
  }

  .floating-form-rail[data-ready='true'] .floating-form-rail__toggle { display: flex; }

  .floating-form-rail__toggle:hover,
  .floating-form-rail__toggle:focus-visible {
    background: var(--color-graphite);
  }

  .floating-form-rail__toggle-icon { align-items: center; display: inline-flex; }
  .floating-form-rail__toggle-icon--expanded { display: none; }
  .floating-form-rail[data-expanded='true'] .floating-form-rail__toggle-icon--collapsed { display: none; }
  .floating-form-rail[data-expanded='true'] .floating-form-rail__toggle-icon--expanded { display: inline-flex; }

  .floating-form-rail__panel {
    background: var(--color-process-white);
    border: 1px solid var(--color-brushed-steel);
    border-block-start: 2px solid var(--color-paradise-orange);
    display: grid;
    filter: none;
    inline-size: min(12rem, calc(100vw - 2.75rem));
    padding: var(--space-1) var(--space-3);
    pointer-events: auto;
  }

  .floating-form-rail__panel[inert] {
    pointer-events: none;
  }

  .floating-form-rail__panel a {
    background: transparent;
    border-block-end: 1px solid var(--color-brushed-steel);
    color: var(--color-graphite);
    justify-content: space-between;
    min-block-size: 2.75rem;
    padding-inline: 0.25rem;
    transition: background-color var(--transition-fast), color var(--transition-fast);
  }

  .floating-form-rail__panel a:last-child { border-block-end: 0; }

  .floating-form-rail__panel a:hover,
  .floating-form-rail__panel a:focus-visible {
    background: var(--color-cold-paper);
    color: var(--color-graphite);
  }

  @media (max-width: 48rem) {
    .floating-form-rail {
      align-items: flex-start;
      flex-direction: row;
      inset-block-end: 1rem;
      inset-inline-end: 1rem;
      inline-size: min(16.75rem, calc(100vw - 2rem));
      top: auto;
      transform: none;
    }

    .floating-form-rail__panel { max-block-size: 16rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .floating-form-rail[data-ready='true'] { transition: none; }

    .floating-form-rail__panel,
    .floating-form-rail__toggle,
    .floating-form-rail__toggle-icon,
    .floating-form-rail__panel a {
      transition: none;
    }
  }
</style>
