---
import { Image } from 'astro:assets';
import paradiseLogo from '../../assets/brand/paradise-fine-foods-logo.png';
import type { Locale } from '../../lib/i18n/types';
import { localizedPath } from '../../lib/i18n/routes';
import { ui } from '../../lib/i18n/ui';

interface Props { locale: Locale; siteName: string }
const { locale, siteName } = Astro.props;
const copy = ui[locale];
---

<footer class="site-footer">
  <div class="site-footer__grid container">
    <div class="site-footer__brand">
      <Image class="site-footer__logo" src={paradiseLogo} alt={siteName} />
      <p>{copy.footer.tagline}</p>
    </div>
    <nav aria-label={copy.footer.navigation}>
      <p class="site-footer__label">{copy.footer.navigation}</p>
      <a href={localizedPath(locale, 'products')}>{copy.header.products}</a>
      <a href={localizedPath(locale, 'brands')}>{copy.header.brands}</a>
    </nav>
    <div>
      <p class="site-footer__label">{copy.footer.contact}</p>
      <a href={localizedPath(locale, 'contact')}>{copy.header.contact}</a>
    </div>
    <div class="site-footer__legal">
      <p>{copy.footer.legal}</p>
      <p>© {new Date().getFullYear()} {copy.footer.copyright}</p>
    </div>
  </div>
</footer>

<style>
  .site-footer { background: var(--color-graphite); color: var(--color-cold-paper); padding-block: var(--space-8) var(--space-6); }
  .site-footer__grid { display: grid; gap: var(--space-7); grid-template-columns: 2fr 1fr 1fr; }
  .site-footer__brand { max-inline-size: 24rem; }
  .site-footer__logo { block-size: auto; inline-size: 7.5rem; margin-block-end: var(--space-3); }
  .site-footer__label { color: var(--color-brushed-steel); font-size: var(--text-xs); letter-spacing: var(--tracking-label); margin-block-end: var(--space-3); text-transform: uppercase; }
  .site-footer a { align-items: center; color: inherit; display: inline-flex; inline-size: max-content; margin-block-end: var(--space-2); min-block-size: 2.75rem; }
  .site-footer__legal { border-top: 1px solid var(--color-brushed-steel); display: flex; font-size: var(--text-xs); gap: var(--space-4); grid-column: 1 / -1; justify-content: space-between; padding-block-start: var(--space-5); }
  @media (max-width: 44rem) { .site-footer__grid { grid-template-columns: 1fr 1fr; } .site-footer__brand, .site-footer__legal { grid-column: 1 / -1; } .site-footer__legal { flex-direction: column; } }
</style>
