---
interface Props {
  modelSrc: string;
  posterSrc: string;
  mobilePosterSrc: string;
  alt: string;
  interactionPrompt: string;
  accessibleLabel: string;
  readyStatus: string;
  fallbackStatus: string;
}

const {
  modelSrc,
  posterSrc,
  mobilePosterSrc,
  alt,
  interactionPrompt,
  accessibleLabel,
  readyStatus,
  fallbackStatus,
} = Astro.props;
const statusId = 'featured-product-stage-status';
---

<product-stage
  class="product-stage"
  data-model-src={modelSrc}
  data-ready-status={readyStatus}
  data-error-status={fallbackStatus}
  data-interaction-prompt={interactionPrompt}
  data-accessible-label={accessibleLabel}
>
  <picture class="product-stage__poster">
    <source media="(max-width: 36rem)" srcset={mobilePosterSrc} width="800" height="1000" />
    <img
      src={posterSrc}
      width="1600"
      height="1000"
      alt={alt}
      loading="eager"
      decoding="sync"
      fetchpriority="high"
    />
  </picture>
  <canvas class="product-stage__canvas" role="presentation" aria-hidden="true"></canvas>
  <span id={statusId} class="product-stage__status" role="status" aria-live="polite">{fallbackStatus}</span>
</product-stage>

<script>
  import { installStageActivation, type StageActivationController } from '../../lib/three/activation';
  import { shouldEnhance3D } from '../../lib/three/enhancement';
  import { restoreStageFallback, upgradeStageInteraction } from '../../lib/three/stage-state';

  const hasWebGL = () => {
    try {
      const canvas = document.createElement('canvas');
      const context = (
        canvas.getContext('webgl2')
        ?? canvas.getContext('webgl')
        ?? canvas.getContext('experimental-webgl')
      ) as WebGL2RenderingContext | WebGLRenderingContext | null;
      const available = Boolean(context);
      context?.getExtension('WEBGL_lose_context')?.loseContext();
      return available;
    } catch {
      return false;
    }
  };

  class ProductStageElement extends HTMLElement {
    #connected = false;
    #started = false;
    #activation?: StageActivationController;
    #viewer?: { dispose: () => void };
    #session = 0;

    connectedCallback() {
      if (this.#connected) return;
      this.#connected = true;
      const session = ++this.#session;
      const eligible = shouldEnhance3D({
        saveData: navigator.connection?.saveData === true,
        reducedMotion: window.matchMedia('(prefers-reduced-motion: reduce)').matches,
        webglAvailable: hasWebGL(),
      });
      if (!eligible) return;
      const status = this.querySelector<HTMLElement>('[role="status"]');
      if (!status) return;

      upgradeStageInteraction(this, status, {
        accessibleLabel: this.dataset.accessibleLabel ?? '',
        interactionPrompt: this.dataset.interactionPrompt ?? '',
        statusId: status.id,
      });

      const createObserver = 'IntersectionObserver' in window
        ? (onIntersection: (isIntersecting: boolean) => void) => {
            const observer = new IntersectionObserver((entries) => {
              onIntersection(entries.some(({ isIntersecting }) => isIntersecting));
            }, { rootMargin: '0px' });
            return {
              observe: (target: EventTarget) => observer.observe(target as Element),
              disconnect: () => observer.disconnect(),
            };
          }
        : undefined;

      try {
        this.#activation = installStageActivation({
          target: this,
          createObserver,
          activate: () => {
            if (this.#connected && session === this.#session) void this.#enhance();
          },
        });
      } catch {
        this.#fail(status);
      }
    }

    disconnectedCallback() {
      this.#connected = false;
      this.#session += 1;
      this.#activation?.dispose();
      this.#activation = undefined;
      this.#viewer?.dispose();
      this.#viewer = undefined;
      this.#started = false;
      const status = this.querySelector<HTMLElement>('[role="status"]') ?? undefined;
      restoreStageFallback(this, status, this.dataset.errorStatus ?? '', false);
    }

    #fail(status: HTMLElement) {
      this.#activation?.dispose();
      this.#activation = undefined;
      restoreStageFallback(this, status, this.dataset.errorStatus ?? '', true);
    }

    async #enhance() {
      if (this.#started) return;
      this.#started = true;
      this.#activation = undefined;
      this.setAttribute('aria-busy', 'true');
      const session = this.#session;
      const canvas = this.querySelector<HTMLCanvasElement>('.product-stage__canvas');
      const status = this.querySelector<HTMLElement>('[role="status"]');
      const modelSrc = this.dataset.modelSrc;
      if (!status) return;
      if (!canvas || !modelSrc) {
        this.#fail(status);
        return;
      }

      try {
        const { mountProductViewer } = await import('../../lib/three/viewer');
        if (!this.#connected || session !== this.#session) return;
        this.#viewer = mountProductViewer({
          canvas,
          modelSrc,
          onReady: () => {
            if (!this.#connected || session !== this.#session) return;
            delete this.dataset.failed;
            this.dataset.ready = 'true';
            this.setAttribute('aria-busy', 'false');
            status.textContent = this.dataset.readyStatus ?? '';
          },
          onError: () => {
            if (this.#connected && session === this.#session) this.#fail(status);
          },
        });
      } catch {
        if (this.#connected && session === this.#session) this.#fail(status);
      }
    }
  }

  if (!customElements.get('product-stage')) customElements.define('product-stage', ProductStageElement);
</script>

<style>
  .product-stage { aspect-ratio: 16 / 10; background: var(--color-paper-white); display: grid; inline-size: 100%; isolation: isolate; overflow: hidden; position: relative; }
  .product-stage__poster, .product-stage__poster img, .product-stage__canvas { block-size: 100%; grid-area: 1 / 1; inline-size: 100%; }
  .product-stage__poster { opacity: 1; transition: opacity 240ms ease; z-index: 1; }
  .product-stage__poster img { object-fit: cover; }
  .product-stage__canvas { cursor: grab; opacity: 0; pointer-events: none; touch-action: pan-y; transition: opacity 240ms ease; z-index: 2; }
  .product-stage__canvas:active { cursor: grabbing; }
  .product-stage[data-ready='true'] .product-stage__canvas { opacity: 1; pointer-events: auto; }
  .product-stage[data-ready='true'] .product-stage__poster { opacity: 0; }
  .product-stage__status { background: color-mix(in srgb, var(--color-paper-white) 92%, transparent); border: 1px solid var(--color-stainless); inset-block-end: var(--space-3); inset-inline-start: var(--space-3); max-inline-size: calc(100% - 2 * var(--space-3)); padding: var(--space-2) var(--space-3); position: absolute; z-index: 3; }
  .product-stage[data-ready='true'] .product-stage__status { opacity: 0; pointer-events: none; }
  @media (max-width: 36rem) { .product-stage { aspect-ratio: 4 / 5; } }
  @media (prefers-reduced-motion: reduce) { .product-stage__poster, .product-stage__canvas { transition: none; } }
</style>
