---
import type { Locale } from '../../lib/i18n/types';

interface Props {
  locale: Locale;
  modelSrc: string;
  posterSrc: string;
  alt: string;
  interactionPrompt: string;
}

const { locale, modelSrc, posterSrc, alt, interactionPrompt } = Astro.props;
const statusCopy = locale === 'vi'
  ? { ready: 'Bản xem 3D đã sẵn sàng.', fallback: 'Hình ảnh xem trước vẫn sẵn sàng.' }
  : { ready: '3D preview ready.', fallback: 'The image preview remains available.' };
---

<product-stage
  class="product-stage"
  data-model-src={modelSrc}
  data-ready-status={statusCopy.ready}
  data-error-status={statusCopy.fallback}
  tabindex="0"
>
  <img
    class="product-stage__poster"
    src={posterSrc}
    width="1200"
    height="1000"
    alt={alt}
    fetchpriority="high"
  />
  <canvas class="product-stage__canvas" role="img" aria-label={alt}></canvas>
  <span class="product-stage__status" role="status" aria-live="polite">{interactionPrompt}</span>
</product-stage>

<script>
  import { shouldEnhance3D } from '../../lib/three/enhancement';

  const hasWebGL = () => {
    try {
      const canvas = document.createElement('canvas');
      const context = (
        canvas.getContext('webgl2')
        ?? canvas.getContext('webgl')
        ?? canvas.getContext('experimental-webgl')
      ) as WebGL2RenderingContext | WebGLRenderingContext | null;
      const available = Boolean(context);
      context?.getExtension('WEBGL_lose_context')?.loseContext();
      return available;
    } catch {
      return false;
    }
  };

  class ProductStageElement extends HTMLElement {
    #connected = false;
    #started = false;
    #observer?: IntersectionObserver;
    #viewer?: { dispose: () => void };
    #session = 0;
    #activate = () => void this.#enhance();

    connectedCallback() {
      if (this.#connected) return;
      this.#connected = true;
      const session = ++this.#session;
      const eligible = shouldEnhance3D({
        saveData: navigator.connection?.saveData === true,
        reducedMotion: window.matchMedia('(prefers-reduced-motion: reduce)').matches,
        webglAvailable: hasWebGL(),
      });

      if (!eligible) return;

      this.addEventListener('focusin', this.#activate);
      this.addEventListener('pointerenter', this.#activate);
      this.addEventListener('pointerdown', this.#activate);

      if ('IntersectionObserver' in window) {
        this.#observer = new IntersectionObserver((entries) => {
          if (session === this.#session && entries.some(({ isIntersecting }) => isIntersecting)) this.#activate();
        }, { rootMargin: '0px' });
        this.#observer.observe(this);
      }
    }

    disconnectedCallback() {
      this.#connected = false;
      this.#session += 1;
      this.#removeActivationHooks();
      this.#viewer?.dispose();
      this.#viewer = undefined;
      this.#started = false;
      delete this.dataset.ready;
    }

    #removeActivationHooks() {
      this.removeEventListener('focusin', this.#activate);
      this.removeEventListener('pointerenter', this.#activate);
      this.removeEventListener('pointerdown', this.#activate);
      this.#observer?.disconnect();
      this.#observer = undefined;
    }

    #fail(status: HTMLElement) {
      delete this.dataset.ready;
      this.dataset.failed = 'true';
      status.textContent = this.dataset.errorStatus ?? '';
    }

    async #enhance() {
      if (this.#started) return;
      this.#started = true;
      this.#removeActivationHooks();
      const session = this.#session;

      const canvas = this.querySelector<HTMLCanvasElement>('.product-stage__canvas');
      const status = this.querySelector<HTMLElement>('[role="status"]');
      const modelSrc = this.dataset.modelSrc;
      if (!canvas || !status || !modelSrc) return;

      try {
        const { mountProductViewer } = await import('../../lib/three/viewer');
        if (!this.#connected || session !== this.#session) return;
        this.#viewer = mountProductViewer({
          canvas,
          modelSrc,
          onReady: () => {
            if (!this.#connected || session !== this.#session) return;
            delete this.dataset.failed;
            this.dataset.ready = 'true';
            status.textContent = this.dataset.readyStatus ?? '';
          },
          onError: () => {
            if (this.#connected && session === this.#session) this.#fail(status);
          },
        });
      } catch {
        if (this.#connected && session === this.#session) this.#fail(status);
      }
    }
  }

  if (!customElements.get('product-stage')) customElements.define('product-stage', ProductStageElement);
</script>

<style>
  .product-stage { background: var(--color-paper-white); block-size: 100%; display: grid; inline-size: 100%; isolation: isolate; min-block-size: 0; overflow: hidden; position: relative; }
  .product-stage__poster, .product-stage__canvas { block-size: 100%; grid-area: 1 / 1; inline-size: 100%; object-fit: cover; }
  .product-stage__poster { z-index: 1; }
  .product-stage__canvas { cursor: grab; opacity: 0; pointer-events: none; touch-action: pan-y; transition: opacity 240ms ease; z-index: 2; }
  .product-stage__canvas:active { cursor: grabbing; }
  .product-stage[data-ready='true'] .product-stage__canvas { opacity: 1; pointer-events: auto; }
  .product-stage[data-ready='true'] .product-stage__poster { opacity: 0; }
  .product-stage__status { background: color-mix(in srgb, var(--color-paper-white) 92%, transparent); border: 1px solid var(--color-stainless); inset-block-end: var(--space-3); inset-inline-start: var(--space-3); max-inline-size: calc(100% - 2 * var(--space-3)); padding: var(--space-2) var(--space-3); position: absolute; z-index: 3; }
  .product-stage[data-ready='true'] .product-stage__status { opacity: 0; pointer-events: none; }
  @media (prefers-reduced-motion: reduce) { .product-stage__canvas { transition: none; } }
</style>
