---
import type { Brand } from '../../lib/cms/types';
import type { Locale } from '../../lib/i18n/types';
import { localizedPath } from '../../lib/i18n/routes';
import { ui } from '../../lib/i18n/ui';

interface Props { brand: Brand; locale: Locale; index?: number; headingLevel?: 'h2' | 'h3' }
const { brand, locale, headingLevel = 'h3' } = Astro.props;
const href = `${localizedPath(locale, 'brands')}${brand.slug}/`;
const Heading = headingLevel;
const accentClasses: Record<Brand['accent'], string> = {
  butter: 'brand-card--butter',
  bordeaux: 'brand-card--bordeaux',
  'cold-chain': 'brand-card--blue',
};
---

<article class:list={['brand-card', 'brand-card__organic-field', accentClasses[brand.accent]]}>
  <div>
    <p class="brand-card__origin">{brand.origin}</p>
    <Heading>{brand.name}</Heading>
    <p>{brand.description}</p>
  </div>
  <a href={href}>{ui[locale].brand.viewBrand}<span aria-hidden="true">↗</span></a>
</article>

<style>
  .brand-card--butter { --brand-accent: var(--color-paradise-green); }
  .brand-card--bordeaux { --brand-accent: var(--color-paradise-coral); }
  .brand-card--blue { --brand-accent: var(--color-paradise-blue); }
  .brand-card__organic-field { background: color-mix(in srgb, var(--brand-accent) 10%, var(--color-paper-white)); border-radius: 42% 58% 38% 62% / 15% 18% 14% 16%; display: grid; gap: var(--space-5); grid-template-columns: minmax(0, 2fr) minmax(10rem, 1fr); margin-block-end: var(--space-5); padding: clamp(var(--space-5), 4vw, var(--space-7)); }
  .brand-card__origin { color: var(--color-deep-herb); font-size: var(--text-xs); font-weight: 700; letter-spacing: var(--tracking-label); text-transform: uppercase; }
  .brand-card :is(h2, h3) { font-size: var(--text-xl); margin-block: var(--space-2); }
  .brand-card a { align-items: center; align-self: end; border-block-start: 2px solid var(--color-paradise-orange); color: var(--color-deep-herb); display: flex; font-size: var(--text-sm); font-weight: 700; justify-content: space-between; min-block-size: 2.75rem; padding-block-start: var(--space-3); text-decoration: none; }
  @media (max-width: 42rem) { .brand-card { border-radius: 2.5rem 0 2.5rem 0; grid-template-columns: 1fr; } }
</style>
