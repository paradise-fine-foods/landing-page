---
import type { Brand } from '../../lib/cms/types';
import type { Locale } from '../../lib/i18n/types';
import { localizedPath } from '../../lib/i18n/routes';
import { ui } from '../../lib/i18n/ui';

interface Props { brand: Brand; locale: Locale; index?: number; headingLevel?: 'h2' | 'h3' }
const { brand, locale, index = 1, headingLevel = 'h3' } = Astro.props;
const href = `${localizedPath(locale, 'brands')}${brand.slug}/`;
const Heading = headingLevel;
---

<article class="brand-card">
  <div class="brand-card__index" aria-hidden="true">PFF / {String(index).padStart(2, '0')}</div>
  <div>
    <p class="brand-card__origin">{brand.origin}</p>
    <Heading>{brand.name}</Heading>
    <p>{brand.description}</p>
  </div>
  <a href={href}>{ui[locale].brand.viewBrand}<span aria-hidden="true">↗</span></a>
</article>

<style>
  .brand-card { border-block: 1px solid var(--color-stainless); display: grid; gap: var(--space-5); grid-template-columns: 0.55fr 2fr 1fr; padding-block: var(--space-5); }
  .brand-card__index, .brand-card__origin { color: var(--color-cold-chain-blue); font-size: var(--text-xs); letter-spacing: var(--tracking-label); text-transform: uppercase; }
  .brand-card :is(h2, h3) { font-size: var(--text-xl); margin-block: var(--space-2); }
  .brand-card a { align-items: center; align-self: end; color: var(--color-carbon); display: flex; font-size: var(--text-sm); font-weight: 600; justify-content: space-between; text-decoration: none; }
  @media (max-width: 42rem) { .brand-card { grid-template-columns: 1fr; } .brand-card__index { display: none; } }
</style>
