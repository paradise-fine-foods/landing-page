---
import type { Brand, BrandAccent, Product } from '../../lib/cms/types';
import type { Locale } from '../../lib/i18n/types';
import type { UiCopy } from '../../lib/i18n/ui';
import ProductCard from '../catalog/ProductCard.astro';

interface Props {
  brand: Brand;
  products: Product[];
  locale: Locale;
  copy: UiCopy;
}

const { brand, products, locale, copy } = Astro.props;
const categories = [...new Map(
  products.flatMap(({ categories }) => categories).map((category) => [category.id, category]),
).values()];
const accentClasses: Record<BrandAccent, string> = {
  butter: 'brand-detail--butter',
  bordeaux: 'brand-detail--bordeaux',
  'cold-chain': 'brand-detail--cold-chain',
};
---

<article class:list={['brand-detail', 'brand-detail--living', accentClasses[brand.accent]]}>
  <header class="brand-detail__hero">
    <div class="brand-detail__identity">
      <p class="brand-detail__eyebrow">{copy.brand.eyebrow}</p>
      <h1>{brand.name}</h1>
      <dl>
        <div class="brand-detail__badge">
          <dt>{copy.brand.origin}</dt>
          <dd>{brand.origin}</dd>
        </div>
      </dl>
    </div>
    <figure class="brand-detail__visual">
      <span aria-hidden="true"></span>
      <img src={brand.image.src} width={brand.image.width} height={brand.image.height} alt={brand.image.alt} />
    </figure>
  </header>

  <div class="brand-detail__editorial">
    <section aria-labelledby="brand-story-title">
      <h2 id="brand-story-title">{copy.brand.story}</h2>
      <p class="brand-detail__story">{brand.description}</p>
      <aside class="brand-detail__notice" aria-label={copy.demoNoticeLabel}>
        {copy.brand.demoNotice}
      </aside>
    </section>

    <section aria-labelledby="brand-categories-title">
      <h2 id="brand-categories-title">{copy.brand.categories}</h2>
      <ul class="brand-detail__categories">
        {categories.map((category) => <li>{category.name}</li>)}
      </ul>
    </section>
  </div>

  {products.length > 0 && (
    <section class="brand-detail__products" aria-labelledby="brand-products-title">
      <div class="brand-detail__section-heading">
        <h2 id="brand-products-title">{copy.brand.products}</h2>
      </div>
      <div class="brand-detail__grid">
        {products.map((product) => <ProductCard {product} {locale} headingLevel="h3" />)}
      </div>
    </section>
  )}
</article>

<style>
  .brand-detail { min-inline-size: 0; }
  .brand-detail--butter { --brand-accent: var(--color-paradise-green); }
  .brand-detail--bordeaux { --brand-accent: var(--color-paradise-coral); }
  .brand-detail--cold-chain { --brand-accent: var(--color-paradise-blue); }
  .brand-detail__hero { display: grid; gap: clamp(var(--space-6), 7vw, var(--space-9)); grid-template-columns: minmax(0, 0.8fr) minmax(0, 1.2fr); padding-block: var(--space-7) var(--space-9); }
  .brand-detail__identity { align-content: center; display: grid; gap: var(--space-5); }
  .brand-detail__eyebrow, .brand-detail__label { color: var(--color-deep-herb); font-size: var(--text-xs); font-weight: 700; letter-spacing: var(--tracking-label); text-transform: uppercase; }
  .brand-detail h1 { font-size: clamp(3rem, 8vw, 7rem); line-height: var(--leading-tight); max-inline-size: 10ch; }
  .brand-detail__badge { border-block-end: 0.25rem solid var(--brand-accent); display: grid; gap: var(--space-2); inline-size: fit-content; padding: var(--space-3) var(--space-5) var(--space-3) 0; }
  .brand-detail__badge dt { color: var(--color-deep-herb); font-size: var(--text-xs); font-weight: 700; letter-spacing: var(--tracking-label); text-transform: uppercase; }
  .brand-detail__badge dd { color: var(--color-deep-herb); font-weight: 600; }
  .brand-detail__visual { aspect-ratio: 3 / 2; background: var(--color-paper-white); border-radius: var(--shape-drop); overflow: hidden; position: relative; }
  .brand-detail__visual span { background: var(--brand-accent); block-size: clamp(4rem, 12vw, 9rem); border-radius: 50% 45% 55% 42%; inline-size: clamp(4rem, 12vw, 9rem); inset-block-start: var(--space-5); inset-inline-end: var(--space-5); opacity: 0.22; position: absolute; z-index: 1; }
  .brand-detail__visual img { block-size: 100%; inline-size: 100%; object-fit: cover; }
  .brand-detail__editorial { background: color-mix(in srgb, var(--brand-accent) 8%, var(--color-paper-white)); border-radius: 3rem 0 3rem 0; display: grid; gap: var(--space-8); grid-template-columns: minmax(0, 1.25fr) minmax(14rem, 0.75fr); padding: clamp(var(--space-6), 5vw, var(--space-8)); }
  .brand-detail__editorial section { align-content: start; display: grid; gap: var(--space-4); }
  .brand-detail__editorial h2, .brand-detail__section-heading h2 { font-size: var(--text-2xl); }
  .brand-detail__story { font-size: var(--text-lg); max-inline-size: var(--measure); }
  .brand-detail__notice { border-inline-start: 0.25rem solid var(--brand-accent); color: var(--color-deep-herb); font-size: var(--text-sm); margin-block-start: var(--space-4); max-inline-size: var(--measure); padding: var(--space-3) var(--space-4); }
  .brand-detail__categories { display: grid; gap: var(--space-2); list-style: none; }
  .brand-detail__categories li { border-block-end: 2px solid color-mix(in srgb, var(--brand-accent) 45%, transparent); color: var(--color-deep-herb); padding-block: var(--space-3); }
  .brand-detail__products { padding-block: var(--space-9); }
  .brand-detail__section-heading { display: grid; gap: var(--space-5); grid-template-columns: minmax(8rem, 1fr) minmax(0, 3fr); margin-block-end: var(--space-7); }
  .brand-detail__grid { display: grid; gap: var(--space-6); grid-template-columns: repeat(3, minmax(0, 1fr)); }
  @media (max-width: 48rem) { .brand-detail__hero, .brand-detail__editorial { grid-template-columns: minmax(0, 1fr); } .brand-detail__visual { grid-row: 1; } .brand-detail__grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
  @media (max-width: 28rem) { .brand-detail__section-heading, .brand-detail__grid { grid-template-columns: minmax(0, 1fr); } .brand-detail__hero { padding-block-start: var(--space-6); } }
</style>
