---
import type { Product } from '../../lib/cms/types';
import type { UiCopy } from '../../lib/i18n/ui';

interface Props {
  product: Product;
  copy: UiCopy['product'];
}

const { product, copy } = Astro.props;
---

<dl class="product-metadata">
  <div><dt>{copy.origin}</dt><dd>{product.origin}</dd></div>
  <div><dt>{copy.category}</dt><dd>{product.categories.map(({ name }) => name).join(' · ')}</dd></div>
  <div><dt>{copy.packFormat}</dt><dd>{product.packFormat}</dd></div>
  <div><dt>{copy.storage}</dt><dd>{product.storage.label} · {product.storage.temperature}</dd></div>
</dl>

<style>
  .product-metadata { border-block: 1px solid var(--color-stainless); display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); }
  .product-metadata div { min-inline-size: 0; padding: var(--space-4); }
  .product-metadata div:nth-child(odd) { border-inline-end: 1px solid var(--color-stainless); }
  .product-metadata div:nth-child(-n + 2) { border-block-end: 1px solid var(--color-stainless); }
  .product-metadata dt { color: var(--color-cold-chain-blue); font-size: 0.66rem; letter-spacing: var(--tracking-label); text-transform: uppercase; }
  .product-metadata dd { margin-block-start: var(--space-2); overflow-wrap: anywhere; }
  @media (max-width: 28rem) { .product-metadata { grid-template-columns: 1fr; } .product-metadata div:nth-child(n) { border-block-end: 1px solid var(--color-stainless); border-inline-end: 0; } .product-metadata div:last-child { border-block-end: 0; } }
</style>
