---
import type { Product } from '../../lib/cms/types';
import type { UiCopy } from '../../lib/i18n/ui';

interface Props {
  product: Product;
  copy: UiCopy['product'];
}

const { product, copy } = Astro.props;
---

<dl class="product-metadata product-detail__facts">
  <div><dt>{copy.origin}</dt><dd>{product.origin}</dd></div>
  <div><dt>{copy.category}</dt><dd>{product.categories.map(({ name }) => name).join(' · ')}</dd></div>
  <div><dt>{copy.packFormat}</dt><dd>{product.packFormat}</dd></div>
  <div><dt>{copy.storage}</dt><dd>{product.storage.label} · {product.storage.temperature}</dd></div>
</dl>

<style>
  .product-metadata { border-inline-start: 2px solid var(--color-paradise-orange); display: grid; gap: var(--space-4); grid-template-columns: repeat(2, minmax(0, 1fr)); padding-inline-start: var(--space-6); }
  .product-metadata div { min-inline-size: 0; }
  .product-metadata dt { color: var(--color-deep-herb); font-size: 0.66rem; font-weight: 700; letter-spacing: var(--tracking-label); text-transform: uppercase; }
  .product-metadata dd { margin-block-start: var(--space-2); overflow-wrap: anywhere; }
  @media (max-width: 48rem) { .product-metadata { border-inline-start: 0; padding-inline-start: 0; } }
  @media (max-width: 28rem) { .product-metadata { grid-template-columns: 1fr; } }
</style>
