---
import type { Product } from '../../lib/cms/types';
import type { Locale } from '../../lib/i18n/types';
import type { UiCopy } from '../../lib/i18n/ui';
import ProductGrid from './ProductGrid.astro';
import ProductMetadata from './ProductMetadata.astro';

interface Props {
  product: Product;
  relatedProducts: Product[];
  locale: Locale;
  copy: UiCopy;
  enquiryPath: string;
}

const { product, relatedProducts, locale, copy, enquiryPath } = Astro.props;
---

<article class="product-detail">
  <div class="product-detail__stage product-detail__organic-stage">
    <span>{product.brand.name}</span>
    <img src={product.image.src} width={product.image.width} height={product.image.height} alt={product.image.alt} />
  </div>
  <div class="product-detail__content">
    <p class="product-detail__eyebrow">{product.brand.name} / {product.origin}</p>
    <h1>{product.name}</h1>
    <p class="product-detail__description">{product.description}</p>
    <ProductMetadata {product} copy={copy.product} />
    <div class="product-detail__lists">
      <section>
        <h2>{copy.product.applications}</h2>
        <ul>{product.applications.map((application) => <li>{copy.product.applicationNames[application] ?? application}</li>)}</ul>
      </section>
      <section>
        <h2>{copy.product.benefits}</h2>
        <ul>{product.benefits.map((benefit) => <li>{benefit}</li>)}</ul>
      </section>
    </div>
    <a class="product-detail__enquire" href={`${enquiryPath}?product=${encodeURIComponent(product.id)}`}>{copy.product.enquire}<span aria-hidden="true">→</span></a>
  </div>
</article>

{relatedProducts.length > 0 && (
  <section class="related-products" aria-labelledby="related-products-title">
    <h2 id="related-products-title">{copy.product.relatedTitle}</h2>
    <ProductGrid products={relatedProducts.slice(0, 3)} {locale} copy={copy.catalog} showEmptyState={false} />
  </section>
)}

<style>
  .product-detail { display: grid; gap: clamp(var(--space-6), 6vw, var(--space-9)); grid-template-columns: minmax(0, 1.05fr) minmax(20rem, 0.95fr); padding-block: var(--space-7) var(--space-9); }
  .product-detail__organic-stage { align-self: start; aspect-ratio: 1 / 1; background: var(--color-paper-white); border-radius: var(--shape-drop); display: grid; isolation: isolate; overflow: hidden; place-items: center; position: sticky; inset-block-start: var(--space-5); }
  .product-detail__stage::before { background: var(--color-mist-blue); border-radius: 42% 58% 38% 62% / 55% 44% 56% 45%; content: ''; inset: 10%; position: absolute; z-index: 0; }
  .product-detail__stage > span { color: var(--color-deep-herb); font-size: 0.65rem; font-weight: 700; inset-block-start: var(--space-4); inset-inline-start: var(--space-4); letter-spacing: var(--tracking-label); position: absolute; text-transform: uppercase; z-index: 2; }
  .product-detail__stage img { block-size: 100%; inline-size: 100%; object-fit: cover; position: relative; z-index: 1; }
  .product-detail__content { align-content: start; display: grid; gap: var(--space-5); }
  .product-detail__eyebrow { color: var(--color-deep-herb); font-size: var(--text-xs); font-weight: 700; letter-spacing: var(--tracking-label); text-transform: uppercase; }
  .product-detail h1 { font-size: clamp(2.5rem, 6vw, 5.5rem); line-height: var(--leading-tight); }
  .product-detail__description { font-size: var(--text-lg); max-inline-size: var(--measure); }
  .product-detail__lists { display: grid; gap: var(--space-6); grid-template-columns: repeat(2, minmax(0, 1fr)); }
  .product-detail__lists h2 { font-family: var(--font-body); font-size: var(--text-sm); letter-spacing: var(--tracking-label); text-transform: uppercase; }
  .product-detail__lists ul { display: grid; gap: var(--space-2); margin-block-start: var(--space-3); padding-inline-start: 1.1rem; }
  .product-detail__enquire { align-items: center; background: var(--color-deep-herb); border: 1px solid var(--color-paradise-orange); border-radius: 1.5rem 0 1.5rem 0; color: var(--color-paper-white); display: flex; font-weight: 700; justify-content: space-between; min-block-size: 3rem; padding: var(--space-4) var(--space-5); text-decoration: none; }
  .related-products { border-block-start: 2px solid var(--color-paradise-orange); padding-block: var(--space-8); }
  .related-products > h2 { font-size: var(--text-2xl); }
  @media (max-width: 48rem) { .product-detail { grid-template-columns: minmax(0, 1fr); } .product-detail__stage { position: relative; inset-block-start: auto; } .product-detail__facts { border-inline-start: 0; padding-inline-start: 0; } }
  @media (max-width: 28rem) { .product-detail__lists { grid-template-columns: minmax(0, 1fr); } }
</style>
