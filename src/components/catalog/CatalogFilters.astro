---
import type { Brand, Category } from '../../lib/cms/types';
import type { UiCopy } from '../../lib/i18n/ui';

interface Props {
  categories: Category[];
  brands: Brand[];
  applications: string[];
  applicationNames: Record<string, string>;
  copy: UiCopy['catalog'];
  initialCount: number;
}

const { categories, brands, applications, applicationNames, copy, initialCount } = Astro.props;
const initialCountText = `${initialCount} ${initialCount === 1 ? copy.resultSingular : copy.resultPlural}`;
---

<div class="catalog-filters">
  <div class="catalog-filters__search">
    <label for="catalog-search">{copy.searchLabel}</label>
    <input id="catalog-search" type="search" placeholder={copy.searchPlaceholder} autocomplete="off" data-filter-search />
  </div>
  <div class="catalog-filters__select">
    <label for="catalog-category">{copy.categoryLabel}</label>
    <select id="catalog-category" data-filter-category>
      <option value="">{copy.allCategories}</option>
      {categories.map((category) => <option value={category.id} data-category-slug={category.slug}>{category.name}</option>)}
    </select>
  </div>
  <div class="catalog-filters__select">
    <label for="catalog-brand">{copy.brandLabel}</label>
    <select id="catalog-brand" data-filter-brand>
      <option value="">{copy.allBrands}</option>
      {brands.map((brand) => <option value={brand.id}>{brand.name}</option>)}
    </select>
  </div>
  <div class="catalog-filters__select">
    <label for="catalog-application">{copy.applicationLabel}</label>
    <select id="catalog-application" data-filter-application>
      <option value="">{copy.allApplications}</option>
      {applications.map((application) => <option value={application}>{applicationNames[application] ?? application}</option>)}
    </select>
  </div>
  <div class="catalog-filters__summary">
    <p
      data-result-count
      data-result-singular={copy.resultSingular}
      data-result-plural={copy.resultPlural}
      aria-live="polite"
      aria-atomic="true"
    >{initialCountText}</p>
    <button type="button" data-reset-filters>{copy.resetFilters}</button>
  </div>
</div>

<noscript><p class="catalog-filters__noscript">{copy.noScript}</p></noscript>

<script>
  import { deriveCatalogState, initializeCatalogCategory, type CatalogFilterRecord } from '../../lib/catalog/catalog-state';

  const catalogs = document.querySelectorAll<HTMLElement>('[data-catalog]');
  for (const catalog of catalogs) {
    const search = catalog.querySelector<HTMLInputElement>('[data-filter-search]');
    const category = catalog.querySelector<HTMLSelectElement>('[data-filter-category]');
    const brand = catalog.querySelector<HTMLSelectElement>('[data-filter-brand]');
    const application = catalog.querySelector<HTMLSelectElement>('[data-filter-application]');
    const resultCount = catalog.querySelector<HTMLElement>('[data-result-count]');
    const emptyState = catalog.querySelector<HTMLElement>('[data-empty-state]');
    const resetButtons = [...catalog.querySelectorAll<HTMLButtonElement>('[data-reset-filters]')];
    const cards = [...catalog.querySelectorAll<HTMLElement>('[data-product-card]')];

    if (!search || !category || !brand || !application || !resultCount || !emptyState || resetButtons.length === 0) continue;

    const records: CatalogFilterRecord[] = cards.map((card) => ({
      id: card.dataset.productId ?? '',
      search: card.dataset.search ?? '',
      categories: JSON.parse(card.dataset.categories ?? '[]') as string[],
      brand: card.dataset.brand ?? '',
      applications: JSON.parse(card.dataset.applications ?? '[]') as string[],
    }));

    const update = () => {
      const state = deriveCatalogState(records, {
        search: search.value,
        category: category.value,
        brand: brand.value,
        application: application.value,
      });
      const visibleIds = new Set(state.visibleIds);
      cards.forEach((card) => { card.hidden = !visibleIds.has(card.dataset.productId ?? ''); });
      const label = state.count === 1 ? resultCount.dataset.resultSingular : resultCount.dataset.resultPlural;
      resultCount.textContent = `${state.count} ${label ?? ''}`;
      emptyState.hidden = !state.empty;
    };

    const categoryOptions = [...category.options].flatMap((option) => {
      const slug = option.dataset.categorySlug;
      return slug ? [{ id: option.value, slug }] : [];
    });
    initializeCatalogCategory({
      selectCategory(categoryId) { category.value = categoryId; },
      update,
    }, new URL(window.location.href).searchParams.get('category'), categoryOptions);

    search.addEventListener('input', update);
    category.addEventListener('change', update);
    brand.addEventListener('change', update);
    application.addEventListener('change', update);
    resetButtons.forEach((reset) => {
      reset.addEventListener('click', () => {
        search.value = '';
        category.value = '';
        brand.value = '';
        application.value = '';
        update();
        search.focus();
      });
    });
  }
</script>

<style>
  .catalog-filters { border-block: 1px solid var(--color-stainless); display: grid; gap: var(--space-4); grid-template-columns: minmax(12rem, 2fr) repeat(3, minmax(9rem, 1fr)); padding-block: var(--space-5); }
  .catalog-filters label { color: var(--color-cold-chain-blue); display: block; font-size: 0.68rem; font-weight: 600; letter-spacing: var(--tracking-label); margin-block-end: var(--space-2); text-transform: uppercase; }
  .catalog-filters input,
  .catalog-filters select { background: var(--color-paper-white); border: 1px solid var(--color-stainless); border-radius: 0; inline-size: 100%; min-block-size: 3rem; padding-inline: var(--space-3); }
  .catalog-filters__summary { align-items: center; display: flex; grid-column: 1 / -1; justify-content: space-between; }
  .catalog-filters__summary p { font-size: var(--text-sm); font-weight: 600; }
  .catalog-filters__summary button { background: transparent; border: 0; color: var(--color-cold-chain-blue); cursor: pointer; min-block-size: 2.75rem; padding: var(--space-2); text-decoration: underline; text-underline-offset: 0.2em; }
  .catalog-filters__noscript { border-inline-start: 0.25rem solid var(--color-cultured-butter); margin-block-start: var(--space-4); padding: var(--space-3) var(--space-4); }
  @media (max-width: 56rem) { .catalog-filters { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
  @media (max-width: 36rem) { .catalog-filters { grid-template-columns: minmax(0, 1fr); } .catalog-filters__summary { align-items: flex-start; flex-direction: column; } }
</style>
