---
import type { Product } from '../../lib/cms/types';
import type { Locale } from '../../lib/i18n/types';
import { getProductCardMetadata } from '../../lib/catalog/product-card';
import { localizedPath } from '../../lib/i18n/routes';
import { ui } from '../../lib/i18n/ui';

interface Props { product: Product; locale: Locale; headingLevel?: 'h2' | 'h3' }
const { product, locale, headingLevel = 'h3' } = Astro.props;
const href = `${localizedPath(locale, 'products')}${product.slug}/`;
const Heading = headingLevel;
const categoryApplications = getProductCardMetadata(product, ui[locale].product.applicationNames);
---

<article class="product-card">
  <a class="product-card__image product-card__organic-media" href={href} tabindex="-1" aria-hidden="true">
    <img src={product.image.src} width={product.image.width} height={product.image.height} alt="" loading="lazy" />
  </a>
  <div class="product-card__meta">
    <span>{product.brand.name}</span>
    <span>{product.packFormat}</span>
  </div>
  <Heading><a href={href}>{product.name}</a></Heading>
  <dl class="product-card__specs">
    {categoryApplications.length > 0 && <div><dt>{ui[locale].product.category}</dt><dd>{categoryApplications.join(' · ')}</dd></div>}
    <div><dt>{ui[locale].product.origin}</dt><dd>{product.origin}</dd></div>
    <div><dt>{ui[locale].product.storage}</dt><dd>{product.storage.label} · {product.storage.temperature}</dd></div>
  </dl>
  <a class="product-card__link" href={href}>{ui[locale].product.viewDetails}<span aria-hidden="true">→</span></a>
</article>

<style>
  .product-card { border: 0; display: grid; gap: var(--space-3); }
  .product-card__organic-media { aspect-ratio: 1 / 1; background: var(--color-paper-white); border-radius: var(--shape-drop); display: block; isolation: isolate; overflow: hidden; position: relative; }
  .product-card__organic-media::before { background: var(--color-mist-blue); border-radius: 48% 52% 64% 36% / 57% 39% 61% 43%; content: ''; inset: 12%; position: absolute; z-index: -1; }
  .product-card__image img { block-size: 100%; inline-size: 100%; object-fit: cover; transition: transform var(--transition-base); }
  .product-card:hover .product-card__image img { transform: scale(1.018); }
  .product-card__meta { border-block-start: 2px solid var(--color-paradise-orange); color: var(--color-deep-herb); display: flex; font-size: 0.68rem; font-weight: 700; justify-content: space-between; letter-spacing: 0.05em; padding-block-start: var(--space-3); text-transform: uppercase; }
  .product-card :is(h2, h3) { font-size: clamp(1.45rem, 2vw, 1.9rem); }
  .product-card :is(h2, h3) a { color: var(--color-deep-herb); text-decoration: none; }
  .product-card__specs { margin: 0; }
  .product-card__specs div { display: grid; gap: var(--space-3); grid-template-columns: 5.5rem 1fr; padding-block: var(--space-2); }
  .product-card__specs dt { color: var(--color-deep-herb); font-size: 0.63rem; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase; }
  .product-card__specs dd { font-size: var(--text-xs); line-height: 1.45; }
  .product-card__link { align-items: center; color: var(--color-deep-herb); display: flex; font-size: var(--text-sm); font-weight: 700; justify-content: space-between; margin-block-start: auto; min-block-size: 2.75rem; padding-block-start: var(--space-2); text-decoration: none; }
</style>
