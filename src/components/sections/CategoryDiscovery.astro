---
import type { Category } from '../../lib/cms/types';
import OrganicMark from '../global/OrganicMark.astro';

interface Props { eyebrow: string; title: string; description: string; categories: Category[]; categoryCounts: Record<string, number>; productLabel: string; productsPath: string }
const { eyebrow, title, description, categories, categoryCounts, productLabel, productsPath } = Astro.props;
const marks = [
  { variant: 'drop', color: 'orange' },
  { variant: 'seed', color: 'blue' },
  { variant: 'petal', color: 'green' },
  { variant: 'seed', color: 'coral' },
] as const;
---

<section class="category-discovery section-space" aria-labelledby="category-title">
  <div class="container category-discovery__heading" data-reveal>
    <p class="eyebrow">{eyebrow}</p>
    <h2 id="category-title">{title}</h2>
    <p>{description}</p>
  </div>
  <div class="container category-discovery__loose-table">
    {categories.map((category, index) => (
      <a class:list={['category-discovery__item', index === 0 && 'category-discovery__feature']} href={`${productsPath}?category=${category.slug}`} data-reveal>
        <div class="category-discovery__media">
          <img src={category.image.src} width={category.image.width} height={category.image.height} alt={category.image.alt} loading="lazy" />
          <OrganicMark variant={marks[index % marks.length].variant} color={marks[index % marks.length].color} class="category-discovery__mark" />
        </div>
        <div class="category-discovery__copy">
          <strong>{category.name}</strong>
          <small>{category.description}</small>
          <span>{categoryCounts[category.id]} {productLabel}</span>
        </div>
      </a>
    ))}
  </div>
</section>

<style>
  .category-discovery { background: var(--color-paper-white); overflow: hidden; }
  .category-discovery__heading { display: grid; gap: var(--space-5); grid-template-columns: 1fr 2fr 2fr; margin-block-end: var(--space-8); }
  .category-discovery__heading > p:last-child { max-inline-size: var(--measure); }
  .category-discovery__loose-table { display: grid; gap: clamp(var(--space-6), 7vw, var(--space-9)); grid-template-columns: repeat(2, minmax(0, 1fr)); }
  .category-discovery__item { color: var(--color-deep-herb); display: grid; gap: var(--space-4); grid-template-columns: minmax(8rem, 0.75fr) minmax(10rem, 1fr); text-decoration: none; }
  .category-discovery__item:nth-child(2) { translate: 0 var(--space-8); }
  .category-discovery__item:nth-child(3) { margin-inline-start: clamp(0rem, 5vw, 5rem); }
  .category-discovery__item:nth-child(4) { margin-inline-end: clamp(0rem, 4vw, 4rem); translate: 0 var(--space-6); }
  .category-discovery__media { aspect-ratio: 1 / 0.92; background: var(--color-mist-blue); border-radius: var(--shape-drop); overflow: hidden; position: relative; }
  .category-discovery__media img { block-size: 100%; inline-size: 100%; object-fit: cover; transition: transform var(--transition-base); }
  .category-discovery__item:hover img { transform: scale(1.02); }
  :global(.category-discovery__mark) { inline-size: 2.35rem; inset-block-end: var(--space-3); inset-inline-end: var(--space-3); position: absolute; }
  .category-discovery__copy { align-content: center; border-block-start: 2px solid var(--color-paradise-orange); display: grid; gap: var(--space-2); padding-block-start: var(--space-3); }
  .category-discovery__copy strong { font-family: var(--font-display); font-size: var(--text-xl); font-weight: 500; }
  .category-discovery__copy small { font-size: var(--text-sm); line-height: 1.55; }
  .category-discovery__copy span { color: var(--color-deep-herb); font-size: var(--text-xs); font-weight: 600; letter-spacing: var(--tracking-label); text-transform: uppercase; }
  :global([data-motion-enhanced]) [data-reveal] { opacity: 0; transform: translateY(1.5rem); }
  :global([data-motion-enhanced]) [data-reveal][data-revealed='true'] { opacity: 1; transform: none; transition: opacity 600ms ease, transform 700ms cubic-bezier(.2,.75,.25,1); }
  @media (max-width: 50rem) { .category-discovery__heading, .category-discovery__loose-table { grid-template-columns: 1fr; } .category-discovery__item, .category-discovery__item:nth-child(n) { margin: 0; translate: none; } }
  @media (max-width: 34rem) { .category-discovery__item { grid-template-columns: 7.5rem 1fr; } }
  @media (prefers-reduced-motion: reduce) { :global([data-motion-enhanced]) [data-reveal] { opacity: 1; transform: none; transition: none; } }
</style>
