---
import type { Brand, Product } from '../../lib/cms/types';
import type { Locale } from '../../lib/i18n/types';
import { localizedPath } from '../../lib/i18n/routes';
import { ui } from '../../lib/i18n/ui';
import OrganicMark from '../global/OrganicMark.astro';

interface Props { eyebrow: string; title: string; selectedBrand: Brand; selectedBrandProducts: Product[]; remainingBrands: Brand[]; locale: Locale }
const { eyebrow, title, selectedBrand, selectedBrandProducts, remainingBrands, locale } = Astro.props;
const brandHref = `${localizedPath(locale, 'brands')}${selectedBrand.slug}/`;
const brandBase = localizedPath(locale, 'brands');
const productBase = localizedPath(locale, 'products');
const copy = ui[locale];
---

<section class="featured-brands section-space" aria-labelledby="featured-brands-title">
  <div class="container section-heading" data-reveal>
    <p class="eyebrow">{eyebrow}</p><h2 id="featured-brands-title">{title}</h2>
  </div>
  <div class="container featured-brands__story" data-reveal>
    <div class="featured-brands__story-mask">
      <img src={selectedBrand.image.src} width={selectedBrand.image.width} height={selectedBrand.image.height} alt={selectedBrand.image.alt} loading="lazy" />
    </div>
    <div class="featured-brands__copy">
      <p class="eyebrow">{copy.brand.story}</p>
      <h3>{selectedBrand.name}</h3>
      <p class="featured-brands__origin">{copy.brand.origin} — {selectedBrand.origin}</p>
      <p>{selectedBrand.description}</p>
      <div class="featured-brands__products">
        <p>{copy.brand.products}</p>
        <div>
          {selectedBrandProducts.map((product, index) => (
            <a href={`${productBase}${product.slug}/`}>
              <OrganicMark variant={index % 2 === 0 ? 'drop' : 'seed'} color={index % 2 === 0 ? 'orange' : 'green'} />
              <span>{product.name}</span>
            </a>
          ))}
        </div>
      </div>
      <a class="featured-brands__cta" href={brandHref}>{copy.brand.viewBrand}<span aria-hidden="true">↗</span></a>
    </div>
  </div>
  <div class="container featured-brands__secondary" data-reveal>
    {remainingBrands.map((brand) => (
      <article>
        <p>{brand.origin}</p>
        <h3>{brand.name}</h3>
        <p>{brand.description}</p>
        <a href={`${brandBase}${brand.slug}/`}>{copy.brand.viewBrand}<span aria-hidden="true">→</span></a>
      </article>
    ))}
  </div>
</section>

<style>
  .featured-brands { background: var(--color-paper-white); overflow: hidden; }
  .featured-brands__story { align-items: center; display: grid; gap: clamp(var(--space-6), 7vw, var(--space-9)); grid-template-columns: minmax(0, 7fr) minmax(20rem, 5fr); }
  .featured-brands__story-mask { aspect-ratio: 1.08 / 1; background: var(--color-mist-blue); border-radius: 66% 34% 58% 42% / 46% 62% 38% 54%; overflow: hidden; }
  .featured-brands__story-mask img { block-size: 100%; inline-size: 100%; object-fit: cover; }
  .featured-brands__copy { display: flex; flex-direction: column; gap: var(--space-4); }
  .featured-brands__copy h3 { font-size: var(--text-2xl); }
  .featured-brands__origin { color: var(--color-cold-chain-blue); font-size: var(--text-xs); font-weight: 600; letter-spacing: var(--tracking-label); text-transform: uppercase; }
  .featured-brands__products { border-block-start: 2px solid var(--color-paradise-orange); margin-block-start: var(--space-4); padding-block-start: var(--space-3); }
  .featured-brands__products > p { font-size: var(--text-xs); font-weight: 600; letter-spacing: var(--tracking-label); text-transform: uppercase; }
  .featured-brands__products > div { display: flex; flex-wrap: wrap; gap: var(--space-3); margin-block-start: var(--space-3); }
  .featured-brands__products a { align-items: center; color: var(--color-deep-herb); display: flex; gap: var(--space-2); text-decoration: none; }
  .featured-brands__products :global(svg) { inline-size: 2rem; flex: 0 0 auto; }
  .featured-brands__cta { align-items: center; color: var(--color-deep-herb); display: flex; font-weight: 700; justify-content: space-between; margin-block-start: var(--space-3); min-block-size: 2.75rem; text-decoration: none; }
  .featured-brands__secondary { display: grid; gap: var(--space-5); grid-template-columns: repeat(2, minmax(0, 1fr)); margin-block-start: clamp(var(--space-7), 8vw, var(--space-9)); }
  .featured-brands__secondary article { border-block-start: 1px solid var(--color-paradise-orange); display: grid; gap: var(--space-3); padding-block-start: var(--space-4); }
  .featured-brands__secondary article:nth-child(even) { margin-block-start: var(--space-7); }
  .featured-brands__secondary article > p:first-child { color: var(--color-cold-chain-blue); font-size: var(--text-xs); font-weight: 600; letter-spacing: var(--tracking-label); text-transform: uppercase; }
  .featured-brands__secondary h3 { font-size: var(--text-xl); }
  .featured-brands__secondary a { align-items: center; display: flex; font-weight: 700; justify-content: space-between; min-block-size: 2.75rem; text-decoration: none; }
  :global([data-motion-enhanced]) [data-reveal] { opacity: 0; transform: translateY(1.5rem); }
  :global([data-motion-enhanced]) [data-reveal][data-revealed='true'] { opacity: 1; transform: none; transition: opacity 600ms ease, transform 700ms cubic-bezier(.2,.75,.25,1); }
  @media (max-width: 50rem) { .featured-brands__story { grid-template-columns: 1fr; } .featured-brands__story-mask { aspect-ratio: 1.3 / 1; } }
  @media (max-width: 36rem) { .featured-brands__secondary { grid-template-columns: 1fr; } .featured-brands__secondary article:nth-child(even) { margin-block-start: 0; } }
  @media (prefers-reduced-motion: reduce) { :global([data-motion-enhanced]) [data-reveal] { opacity: 1; transform: none; transition: none; } }
</style>
