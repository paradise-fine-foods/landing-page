---
import type { Product } from '../../lib/cms/types';
import type { UiCopy } from '../../lib/i18n/ui';
import ButtonLink from '../global/ButtonLink.astro';
import OrganicMark from '../global/OrganicMark.astro';

interface Props {
  copy: UiCopy['hero'];
  product: Product;
  productsPath: string;
  contactPath: string;
}

const { copy, product, productsPath, contactPath } = Astro.props;
const metadata = [
  { label: copy.brand, value: product.brand.name },
  { label: copy.origin, value: product.origin },
  { label: copy.packFormat, value: product.packFormat },
  { label: copy.storage, value: `${product.storage.label} · ${product.storage.temperature}` },
];
---

<section class="living-hero" aria-labelledby="hero-title" data-living-hero>
  <div class="living-hero__content container">
    <div class="living-hero__copy">
      <p class="eyebrow">{copy.eyebrow}</p>
      <h1 id="hero-title">{copy.title}</h1>
      <p class="living-hero__description">{copy.description}</p>
      <div class="living-hero__actions">
        <ButtonLink href={productsPath}>{copy.primaryCta}</ButtonLink>
        <ButtonLink href={contactPath} variant="secondary">{copy.secondaryCta}</ButtonLink>
      </div>
      <dl class="living-hero__metadata">
        {metadata.map(({ label, value }) => <div><dt>{label}</dt><dd>{value}</dd></div>)}
      </dl>
    </div>
    <figure class="living-hero__art">
      <div class="living-hero__image-frame">
        <img
          src={product.image.src}
          alt={product.image.alt}
          width={product.image.width}
          height={product.image.height}
          loading="eager"
          fetchpriority="high"
        />
        <OrganicMark variant="drop" color="orange" class="living-hero__mark living-hero__mark--one" />
        <OrganicMark variant="seed" color="blue" class="living-hero__mark living-hero__mark--two" />
        <OrganicMark variant="petal" color="green" class="living-hero__mark living-hero__mark--trio" />
        <canvas data-living-canvas aria-hidden="true"></canvas>
      </div>
      <figcaption>{product.name}</figcaption>
    </figure>
  </div>
</section>

<script>
  import { shouldEnhanceMotion } from '../../lib/motion/preferences';

  interface NavigatorWithConnection extends Navigator {
    connection?: { saveData?: boolean };
  }

  const reduceMotion = globalThis.matchMedia?.('(prefers-reduced-motion: reduce)').matches ?? true;
  const saveData = Boolean((navigator as NavigatorWithConnection).connection?.saveData);

  if (shouldEnhanceMotion({ reduceMotion, saveData })) {
    import('../../lib/motion/living-canvas')
      .then(({ mountLivingCanvas }) => {
        const controllers = [...document.querySelectorAll<HTMLCanvasElement>('[data-living-canvas]')]
          .map((canvas) => mountLivingCanvas(canvas));
        globalThis.addEventListener('pagehide', () => {
          for (const controller of controllers) controller.dispose();
        }, { once: true });
      })
      .catch(() => undefined);
  }
</script>

<style>
  .living-hero { background: var(--color-paper-white); border-block-end: 1px solid var(--color-stainless); overflow: hidden; }
  .living-hero__content { display: grid; grid-template-columns: minmax(18rem, 5fr) minmax(28rem, 7fr); min-block-size: min(48rem, calc(100vh - 7.15rem)); }
  .living-hero__copy { align-self: center; display: flex; flex-direction: column; gap: var(--space-5); padding: var(--space-8) clamp(var(--space-6), 5vw, var(--space-9)) var(--space-8) 0; position: relative; z-index: 2; }
  .living-hero h1 { font-size: clamp(3rem, 5.5vw, 5.8rem); max-inline-size: 10ch; }
  .living-hero__description { max-inline-size: 34rem; }
  .living-hero__actions { display: flex; flex-wrap: wrap; gap: var(--space-3); margin-block-start: var(--space-2); }
  .living-hero__metadata { border-block-start: 1px solid var(--color-stainless); display: grid; grid-template-columns: 1fr 1fr; margin: var(--space-4) 0 0; }
  .living-hero__metadata div { border-block-end: 1px solid var(--color-stainless); min-inline-size: 0; padding: var(--space-3) var(--space-3) var(--space-3) 0; }
  .living-hero__metadata dt { color: var(--color-deep-herb); font-size: 0.7rem; font-weight: 600; letter-spacing: var(--tracking-label); text-transform: uppercase; }
  .living-hero__metadata dd { font-size: 0.82rem; margin-block-start: var(--space-1); overflow-wrap: anywhere; }
  .living-hero__art { align-self: stretch; background: var(--color-morning-mist); border-inline: 1px solid var(--color-stainless); display: grid; grid-template-rows: 1fr auto; margin: 0; min-inline-size: 0; position: relative; }
  .living-hero__image-frame { min-block-size: 35rem; overflow: hidden; position: relative; }
  .living-hero__image-frame > img { block-size: 100%; inline-size: 100%; object-fit: cover; position: absolute; }
  .living-hero__art figcaption { background: var(--color-deep-herb); color: var(--color-paper-white); font-size: 0.78rem; font-weight: 600; letter-spacing: var(--tracking-label); padding: var(--space-3) var(--space-4); text-transform: uppercase; }
  :global(.living-hero__mark) { filter: drop-shadow(0 0.35rem 0.6rem rgb(40 52 43 / 0.1)); position: absolute; z-index: 2; }
  :global(.living-hero__mark--one) { inline-size: clamp(4rem, 8vw, 8rem); inset-block-start: 9%; inset-inline-start: 6%; rotate: -18deg; }
  :global(.living-hero__mark--two) { inline-size: clamp(3.5rem, 7vw, 7rem); inset-block-end: 12%; inset-inline-end: 5%; rotate: 21deg; }
  :global(.living-hero__mark--trio) { inline-size: clamp(2.5rem, 5vw, 5rem); inset-block-start: 13%; inset-inline-end: 8%; opacity: 0.86; rotate: 38deg; }
  [data-living-canvas] { block-size: 100%; inline-size: 100%; inset: 0; pointer-events: none; position: absolute; z-index: 3; }
  @media (max-width: 64rem) { .living-hero__content { grid-template-columns: 1fr; } .living-hero__copy { padding-inline-end: 0; } .living-hero__art { border-block-start: 1px solid var(--color-stainless); } }
  @media (max-width: 36rem) { .living-hero__content { inline-size: 100%; } .living-hero__copy { padding-inline: var(--container-inline); } .living-hero__actions { align-items: stretch; flex-direction: column; } .living-hero__art { border-inline: 0; } .living-hero__image-frame { min-block-size: 30rem; } }
</style>
