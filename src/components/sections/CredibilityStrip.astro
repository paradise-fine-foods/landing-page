---
interface Pillar { title: string; description: string }
interface Props { title: string; pillars: Pillar[] }
const { title, pillars } = Astro.props;
---

<section class="credibility" aria-labelledby="credibility-title" data-reveal>
  <div class="container credibility__flow">
    <h2 id="credibility-title">{title}</h2>
    <ul>{pillars.map(({ title: pillarTitle }) => <li><span aria-hidden="true"></span>{pillarTitle}</li>)}</ul>
  </div>
</section>

<style>
  .credibility { background: var(--color-process-white); border-block-end: 1px solid var(--color-brushed-steel); padding-block: var(--space-6); }
  .credibility__flow { align-items: center; display: grid; gap: var(--space-6); grid-template-columns: 1fr; }
  .credibility h2 { font-family: var(--font-display); font-size: var(--text-2xl); font-weight: 700; line-height: 1.05; max-inline-size: 22ch; }
  .credibility ul { align-items: center; display: flex; flex-wrap: wrap; gap: var(--space-4) var(--space-6); list-style: none; }
  .credibility li { align-items: center; display: flex; font-size: var(--text-xs); font-weight: 700; gap: var(--space-2); }
  .credibility li > span { background: var(--color-graphite); block-size: 0.5rem; inline-size: 0.5rem; }
  :global([data-motion-enhanced]) [data-reveal],
  :global([data-motion-enhanced]) [data-reveal][data-revealed='true'] { opacity: 1; transform: none; transition: none; }
  @media (max-width: 44rem) { .credibility__flow { grid-template-columns: 1fr; } .credibility h2 { max-inline-size: none; } .credibility ul { align-items: start; flex-direction: column; } }
  @media (prefers-reduced-motion: reduce) { :global([data-motion-enhanced]) [data-reveal] { opacity: 1; transform: none; transition: none; } }
</style>
