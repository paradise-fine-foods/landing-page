---
import ButtonLink from '../global/ButtonLink.astro';
interface Props { title: string; description: string; button: string; href: string }
const { title, description, button, href } = Astro.props;
---

<section class="final-cta" aria-labelledby="final-cta-title">
  <div class="container final-cta__grid">
    <p aria-hidden="true">PFF / OPEN LINE</p>
    <div><h2 id="final-cta-title">{title}</h2><p>{description}</p></div>
    <ButtonLink {href}>{button}</ButtonLink>
  </div>
</section>

<style>
  .final-cta { background: var(--color-cultured-butter); padding-block: var(--space-7); }
  .final-cta__grid { align-items: center; display: grid; gap: var(--space-6); grid-template-columns: 0.7fr 2fr auto; }
  .final-cta__grid > p { font-size: var(--text-xs); letter-spacing: var(--tracking-label); }
  .final-cta h2 { font-size: clamp(2rem, 4vw, 3.8rem); }
  .final-cta h2 + p { margin-block-start: var(--space-2); max-inline-size: 42rem; }
  @media (max-width: 48rem) { .final-cta__grid { grid-template-columns: 1fr; } .final-cta__grid > p { display: none; } }
</style>
