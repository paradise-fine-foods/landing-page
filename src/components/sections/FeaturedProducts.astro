---
import type { Product } from '../../lib/cms/types';
import type { Locale } from '../../lib/i18n/types';
import ProductCard from '../catalog/ProductCard.astro';

interface Props { eyebrow: string; title: string; products: Product[]; locale: Locale }
const { eyebrow, title, products, locale } = Astro.props;
---

<section class="featured-products section-space" aria-labelledby="featured-products-title">
  <div class="container section-heading">
    <p class="eyebrow">{eyebrow}</p><h2 id="featured-products-title">{title}</h2>
  </div>
  <div class="container featured-products__grid">
    {products.map((product) => <ProductCard {product} {locale} />)}
  </div>
</section>

<style>
  .featured-products__grid { display: grid; gap: var(--space-5); grid-template-columns: repeat(3, 1fr); }
  @media (max-width: 50rem) { .featured-products__grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 34rem) { .featured-products__grid { grid-template-columns: 1fr; } }
</style>
