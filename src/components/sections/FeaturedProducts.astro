---
import type { Product } from '../../lib/cms/types';
import type { Locale } from '../../lib/i18n/types';
import type { UiCopy } from '../../lib/i18n/ui';
import ProductCard from '../catalog/ProductCard.astro';

interface Props { eyebrow: string; title: string; products: Product[]; locale: Locale; carousel: UiCopy['home']['carousel'] }
const { eyebrow, title, products, locale, carousel } = Astro.props;
const initialStatus = carousel.status.replace('{current}', '1').replace('{total}', String(products.length));
---

<section class="featured-products section-space" aria-labelledby="featured-products-title" aria-roledescription="carousel" aria-label={carousel.label} data-carousel>
  <div class="container featured-products__heading" data-reveal>
    <div><p class="eyebrow">{eyebrow}</p><h2 id="featured-products-title">{title}</h2></div>
    <div class="featured-products__controls" data-carousel-controls hidden>
      <button type="button" data-carousel-previous aria-label={carousel.previous}><span aria-hidden="true">←</span><span>{carousel.previous}</span></button>
      <p aria-live="polite" aria-atomic="true" data-carousel-status data-carousel-status-template={carousel.status}>{initialStatus}</p>
      <button type="button" data-carousel-next aria-label={carousel.next}><span>{carousel.next}</span><span aria-hidden="true">→</span></button>
    </div>
  </div>
  <div class="featured-products__viewport" data-carousel-viewport tabindex="0" data-reveal>
    {products.map((product) => <div class="featured-products__item" data-carousel-item><ProductCard {product} {locale} /></div>)}
  </div>
</section>

<style>
  .featured-products { background: var(--color-rice-paper); overflow: hidden; }
  .featured-products__heading { align-items: end; display: flex; gap: var(--space-6); justify-content: space-between; margin-block-end: var(--space-7); }
  .featured-products__heading h2 { margin-block-start: var(--space-3); }
  .featured-products__controls { align-items: center; display: flex; gap: var(--space-3); }
  .featured-products__controls[hidden] { display: none; }
  .featured-products__controls button { align-items: center; background: transparent; border: 1px solid var(--color-deep-herb); border-radius: 999px; cursor: pointer; display: flex; gap: var(--space-2); justify-content: center; min-block-size: 2.75rem; padding-inline: var(--space-4); }
  .featured-products__controls button:disabled { cursor: default; opacity: 0.42; }
  .featured-products__controls p { font-size: var(--text-xs); font-variant-numeric: tabular-nums; min-inline-size: 3rem; text-align: center; }
  .featured-products__viewport { display: grid; gap: clamp(var(--space-5), 4vw, var(--space-7)); grid-auto-columns: minmax(18rem, calc((100vw - (2 * var(--container-inline)) - (2 * var(--space-7))) / 3)); grid-auto-flow: column; inline-size: min(100% - (2 * var(--container-inline)), var(--container-max)); margin-inline: auto; overflow-x: auto; overscroll-behavior-inline: contain; padding-block: var(--space-2) var(--space-5); scroll-snap-type: inline mandatory; scrollbar-color: var(--color-paradise-orange) var(--color-mist-blue); }
  .featured-products__item { border-block-start: 2px solid var(--color-paradise-orange); min-inline-size: 0; padding-block-start: var(--space-3); scroll-snap-align: start; }
  :global([data-motion-enhanced]) [data-reveal] { opacity: 0; transform: translateY(1.5rem); }
  :global([data-motion-enhanced]) [data-reveal][data-revealed='true'] { opacity: 1; transform: none; transition: opacity 600ms ease, transform 700ms cubic-bezier(.2,.75,.25,1); }
  @media (max-width: 50rem) { .featured-products__viewport { grid-auto-columns: minmax(17rem, 72vw); } }
  @media (max-width: 38rem) { .featured-products__heading { align-items: start; flex-direction: column; } .featured-products__controls { inline-size: 100%; justify-content: space-between; } .featured-products__controls button span:not([aria-hidden]) { position: absolute; clip-path: inset(50%); block-size: 1px; inline-size: 1px; overflow: hidden; white-space: nowrap; } }
  @media (prefers-reduced-motion: reduce) { :global([data-motion-enhanced]) [data-reveal] { opacity: 1; transform: none; transition: none; } [data-carousel-viewport] { scroll-behavior: auto; } }
</style>
