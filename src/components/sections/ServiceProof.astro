---
import type { FeaturedContent } from '../../lib/cms/types';

interface Props { eyebrow: string; title: string; description: string; editorial: FeaturedContent['editorial'] }
const { eyebrow, title, description, editorial } = Astro.props;
---

<section class="service-proof section-space" aria-labelledby="service-title">
  <div class="container service-proof__grid">
    <div class="service-proof__image">
      <img src={editorial.image.src} width={editorial.image.width} height={editorial.image.height} alt={editorial.image.alt} loading="lazy" />
      <span aria-hidden="true">2—6 °C / CONTROLLED</span>
    </div>
    <div class="service-proof__copy">
      <p class="eyebrow">{eyebrow}</p>
      <h2 id="service-title">{title}</h2>
      <p>{description}</p>
      <div class="service-proof__note"><strong>{editorial.title}</strong><p>{editorial.body}</p></div>
    </div>
  </div>
</section>

<style>
  .service-proof { background: var(--color-carbon); color: var(--color-milk-paper); }
  .service-proof__grid { align-items: center; display: grid; gap: clamp(var(--space-6), 7vw, var(--space-9)); grid-template-columns: 7fr 5fr; }
  .service-proof__image { background: var(--color-paper-white); position: relative; }
  .service-proof__image img { inline-size: 100%; }
  .service-proof__image span { background: var(--color-cultured-butter); color: var(--color-carbon); font-size: 0.62rem; inset-block-end: 0; inset-inline-end: 0; letter-spacing: var(--tracking-label); padding: var(--space-2) var(--space-3); position: absolute; }
  .service-proof .eyebrow { color: var(--color-cultured-butter); }
  .service-proof__copy { display: grid; gap: var(--space-5); }
  .service-proof__note { border-top: 1px solid var(--color-stainless); display: grid; gap: var(--space-2); margin-block-start: var(--space-5); padding-block-start: var(--space-4); }
  .service-proof__note strong { font-family: var(--font-display); font-size: var(--text-lg); font-weight: 500; }
  .service-proof__note p { color: var(--color-stainless); font-size: var(--text-sm); }
  @media (max-width: 48rem) { .service-proof__grid { grid-template-columns: 1fr; } }
</style>
