---
import '@fontsource/newsreader/500.css';
import '@fontsource/nunito/400.css';
import '@fontsource/nunito/500.css';
import { Image } from 'astro:assets';
import logo from '../assets/brand/paradise-fine-foods-logo.png';
import OrganicMark from '../components/global/OrganicMark.astro';
import Icon from '../components/global/Icon.astro';
import FloatingFormRail from '../components/global/FloatingFormRail.astro';
import { ui } from '../lib/i18n/ui';
import '../styles/tokens.css';
import '../styles/typography.css';
import '../styles/global.css';

const canonical = new URL('/404.html', Astro.site ?? 'https://paradisefinefoods.com');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>Page not found | Paradise Fine Foods</title>
    <meta name="description" content="Choose an English or Vietnamese Paradise Fine Foods destination after reaching an unavailable page." />
    <meta name="robots" content="noindex" />
    <link rel="canonical" href={canonical} />
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content · <span lang="vi">Chuyển đến nội dung</span></a>
    <header class="not-found-header">
      <a class="not-found__link" href="/en/" aria-label="Paradise Fine Foods — English home">
        <Image src={logo} alt="Paradise Fine Foods" width={158} height={130} />
      </a>
      <p>English · <span lang="vi">Tiếng Việt</span></p>
    </header>

    <main id="main-content" class="not-found">
      <div class="not-found__art" aria-hidden="true">
        <OrganicMark variant="drop" color="orange" class="not-found__drop" />
        <OrganicMark variant="petal" color="green" class="not-found__petal" />
        <Image src={logo} alt="" width={158} height={130} />
        <strong>404</strong>
      </div>

      <div class="not-found__content">
        <section lang="en" aria-labelledby="not-found-en">
          <p class="eyebrow">Page unavailable</p>
          <h1 id="not-found-en">This page could not be found</h1>
          <p>The address may have changed. Choose an English destination below.</p>
          <nav aria-label="English destinations">
        <a class="not-found__link not-found__primary" href="/en/">English home <Icon name="lucide:arrow-right" size="1.05em" /></a>
            <a class="not-found__link" href="/en/products/">Browse English products</a>
          </nav>
        </section>

        <section lang="vi" aria-labelledby="not-found-vi">
          <p class="eyebrow">Trang không khả dụng</p>
          <h2 id="not-found-vi">Không tìm thấy trang này</h2>
          <p>Địa chỉ có thể đã thay đổi. Vui lòng chọn điểm đến tiếng Việt bên dưới.</p>
          <nav aria-label="Điểm đến tiếng Việt">
        <a class="not-found__link not-found__primary" href="/vi/">Trang chủ tiếng Việt <Icon name="lucide:arrow-right" size="1.05em" /></a>
            <a class="not-found__link" href="/vi/products/">Xem sản phẩm tiếng Việt</a>
          </nav>
        </section>
      </div>
    </main>

    <footer class="not-found-footer">
      <p>Exceptional ingredients · <span lang="vi">Nguyên liệu tuyển chọn</span></p>
      <p>Paradise Fine Foods</p>
    </footer>
  <FloatingFormRail locale="en" contactPath="/en/contact/" customerPath="/en/contact/customer/" supplierPath="/en/contact/supplier/" copy={ui.en.floatingRail} staticOnly />
  </body>
</html>

<style>
  body { background: var(--color-cold-paper); color: var(--color-graphite); min-block-size: 100vh; }
  .not-found-header, .not-found-footer { align-items: center; display: flex; font-size: var(--text-xs); justify-content: space-between; letter-spacing: var(--tracking-label); margin-inline: auto; max-inline-size: var(--container-max); padding: var(--space-4) var(--container-inline); text-transform: uppercase; }
  .not-found-header { border-bottom: 1px solid var(--color-brushed-steel); }
  .not-found-header a { align-items: center; color: inherit; display: flex; font-weight: 600; gap: var(--space-3); text-decoration: none; }
  .not-found__link { align-items: center; display: flex; min-block-size: 2.75rem; }
  .not-found-header a img { block-size: 3.5rem; inline-size: auto; }
  .not-found { background: var(--color-process-white); display: grid; grid-template-columns: minmax(15rem, 0.8fr) minmax(0, 2.2fr); margin-inline: auto; max-inline-size: var(--container-max); min-block-size: calc(100vh - 11rem); padding-inline: var(--container-inline); }
  .not-found__art { align-items: center; background: var(--color-cold-paper); display: flex; isolation: isolate; justify-content: center; min-block-size: 30rem; position: relative; }
  .not-found__art img { block-size: auto; inline-size: min(16rem, 62vw); position: relative; z-index: 2; }
  .not-found__art strong { color: var(--color-paradise-orange); font-family: var(--font-body); font-size: clamp(5rem, 12vw, 10rem); font-weight: 500; inset-block-end: 8%; position: absolute; z-index: 3; }
  .not-found__art :global(.organic-mark), :global(.not-found__drop), :global(.not-found__petal) { display: none; }
  .not-found__content { align-content: center; background: var(--color-process-white); display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); }
  .not-found__content section { display: flex; flex-direction: column; min-inline-size: 0; padding: clamp(var(--space-6), 5vw, var(--space-9)); }
  .not-found__content section + section { border-inline-start: 1px solid var(--color-brushed-steel); }
  .not-found__content h1, .not-found__content h2 { font-size: clamp(2.4rem, 5vw, 4.7rem); margin-block: var(--space-4); overflow-wrap: anywhere; }
  .not-found__content section > p:not(.eyebrow) { max-inline-size: 34rem; }
  .not-found__content nav { border-top: 1px solid var(--color-brushed-steel); display: grid; gap: var(--space-3); margin-block-start: auto; padding-block-start: var(--space-6); }
  .not-found__content nav a { color: var(--color-graphite); font-weight: 600; inline-size: fit-content; text-underline-offset: 0.25em; }
  .not-found__content .not-found__primary { align-items: center; background: var(--color-graphite); border: 1px solid var(--color-paradise-orange); border-radius: var(--radius-sm); color: var(--color-process-white); display: flex; inline-size: 100%; justify-content: space-between; min-block-size: 3rem; padding-inline: var(--space-4); text-decoration: none; }
  .not-found-footer { border-top: 1px solid var(--color-brushed-steel); }
  @media (max-width: 58rem) { .not-found { grid-template-columns: 1fr; padding-inline: 0; } .not-found__art { min-block-size: 20rem; } }
  @media (max-width: 40rem) { .not-found-header p, .not-found-footer p + p { display: none; } .not-found__content { grid-template-columns: 1fr; } .not-found__content section + section { border-block-start: 1px solid var(--color-brushed-steel); border-inline-start: 0; } .not-found__content nav { margin-block-start: var(--space-6); } }
</style>
