---
import type { GetStaticPaths, InferGetStaticParamsType, InferGetStaticPropsType } from 'astro';
import BrandDetail from '../../../components/brands/BrandDetail.astro';
import Breadcrumbs from '../../../components/global/Breadcrumbs.astro';
import SiteLayout from '../../../layouts/SiteLayout.astro';
import { brandDetailPath, buildBrandRouteMaps, findBrandRoute } from '../../../lib/brands/routes';
import { getBrands, getProducts } from '../../../lib/cms/queries';
import { localizedPath } from '../../../lib/i18n/routes';
import { counterpartLocale, getLocaleStaticPaths } from '../../../lib/i18n/static-paths';
import { ui } from '../../../lib/i18n/ui';

export const getStaticPaths = (async () => {
  const [englishBrands, vietnameseBrands, englishProducts, vietnameseProducts] = await Promise.all([
    getBrands('en'),
    getBrands('vi'),
    getProducts('en'),
    getProducts('vi'),
  ]);
  const routeMaps = buildBrandRouteMaps(englishBrands, vietnameseBrands);
  const brandsByLocale = { en: englishBrands, vi: vietnameseBrands };
  const productsByLocale = { en: englishProducts, vi: vietnameseProducts };

  return getLocaleStaticPaths().flatMap(({ props: { locale } }) => {
    const brands = brandsByLocale[locale];
    const products = productsByLocale[locale];
    const alternateLocale = counterpartLocale(locale);

    return brands.map((brand) => {
      const pathname = brandDetailPath(locale, brand);
      return {
        params: { locale, slug: brand.slug },
        props: {
          locale,
          brand,
          products: products.filter((product) => product.brand.id === brand.id),
          pathname,
          alternatePath: findBrandRoute(routeMaps, pathname, alternateLocale) ?? localizedPath(alternateLocale, 'brands'),
        },
      };
    });
  });
}) satisfies GetStaticPaths;

type Params = InferGetStaticParamsType<typeof getStaticPaths>;
type Props = InferGetStaticPropsType<typeof getStaticPaths>;
const { locale, brand, products, pathname, alternatePath } = Astro.props as Props;
const localeParam: Params['locale'] = Astro.params.locale;
const slug: Params['slug'] = Astro.params.slug;
void localeParam;
void slug;
const copy = ui[locale];
---

<SiteLayout {locale} title={`${brand.name} | ${copy.siteName}`} description={brand.description} {pathname} {alternatePath} siteName={copy.siteName} image={brand.image.src}>
  <div class="brand-page container section-space">
    <Breadcrumbs label={copy.brand.breadcrumb} items={[{ label: copy.header.home, href: localizedPath(locale, 'home') }, { label: copy.header.brands, href: localizedPath(locale, 'brands') }, { label: brand.name }]} />
    <BrandDetail {brand} {products} {locale} {copy} />
  </div>
</SiteLayout>

<style>.brand-page { min-inline-size: 0; }</style>
