---
import type { GetStaticPaths } from 'astro';
import { productDetailPath } from '../../../lib/catalog/routes';
import { getProducts } from '../../../lib/cms/queries';

export const getStaticPaths = (async () => {
  const products = await getProducts('vi');
  return products.map((product) => ({
    params: { locale: 'vi', slug: product.slug },
    props: { destination: productDetailPath('vi', product) },
  }));
}) satisfies GetStaticPaths;

return Astro.redirect((Astro.props as { destination: string }).destination, 301);
---
