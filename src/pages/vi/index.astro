---
import SiteLayout from '../../layouts/SiteLayout.astro';
import Hero from '../../components/sections/Hero.astro';
import CredibilityStrip from '../../components/sections/CredibilityStrip.astro';
import CategoryDiscovery from '../../components/sections/CategoryDiscovery.astro';
import FeaturedProducts from '../../components/sections/FeaturedProducts.astro';
import FeaturedBrands from '../../components/sections/FeaturedBrands.astro';
import ServiceProof from '../../components/sections/ServiceProof.astro';
import ChannelPathways from '../../components/sections/ChannelPathways.astro';
import FinalCta from '../../components/sections/FinalCta.astro';
import ProductStage from '../../components/three/ProductStage.astro';
import heroPosterDesktopSrc from '../../assets/demo/hero-poster-desktop.svg?no-inline';
import heroPosterMobileSrc from '../../assets/demo/hero-poster-mobile.svg?no-inline';
import { getBrands, getCategories, getFeaturedContent, getGlobalSettings, getProducts } from '../../lib/cms/queries';
import { counterpartPath, localizedPath } from '../../lib/i18n/routes';
import { ui } from '../../lib/i18n/ui';

const locale = 'vi';
const pathname = '/vi/';
const routePairs = [{ en: '/en/', vi: '/vi/' }] as const;
const alternatePath = counterpartPath(pathname, 'en', routePairs);
const [settings, featured, categories, products, brands] = await Promise.all([
  getGlobalSettings(locale), getFeaturedContent(locale), getCategories(locale),
  getProducts(locale, {}), getBrands(locale),
]);
const copy = ui[locale];
const productsPath = localizedPath(locale, 'products');
const contactPath = localizedPath(locale, 'contact');
const categoryCounts = Object.fromEntries(categories.map((category) => [category.id, products.filter((product) => product.categories.some(({ id }) => id === category.id)).length]));
const selectedBrand = brands.find(({ id }) => id === featured.hero.product.brand.id) ?? brands[0];
if (!selectedBrand) throw new Error('Featured brand is required');
const selectedBrandProducts = products.filter((product) => product.brand.id === selectedBrand.id).slice(0, 3);
const remainingBrands = brands.filter(({ id }) => id !== selectedBrand.id);
const channels = [
  { ...copy.home.channels.retail, href: `${contactPath}?interest=retail` },
  { ...copy.home.channels.horeca, href: `${contactPath}?interest=horeca` },
  { ...copy.home.channels.bakery, href: `${contactPath}?interest=bakery` },
  { ...copy.home.channels.ecommerce, href: `${contactPath}?interest=ecommerce` },
];
---

<SiteLayout locale={locale} title={settings.siteName} description={settings.siteDescription} {pathname} {alternatePath} siteName={settings.siteName} demoNotice={settings.demoNotice} image={featured.hero.image.src} preloadImages={[{ href: heroPosterDesktopSrc, media: '(min-width: 36.001rem)' }, { href: heroPosterMobileSrc, media: '(max-width: 36rem)' }]}>
  <Hero copy={copy.hero} product={featured.hero.product} {productsPath} {contactPath}>
    <ProductStage slot="stage" modelSrc="/models/demo-package.glb" posterSrc={heroPosterDesktopSrc} mobilePosterSrc={heroPosterMobileSrc} alt={featured.hero.image.alt} interactionPrompt={copy.hero.interactionPrompt} accessibleLabel={copy.hero.stageAccessibleLabel} readyStatus={copy.hero.stageReadyStatus} fallbackStatus={copy.hero.stageFallbackStatus} />
  </Hero>
  <CredibilityStrip title={copy.home.credibilityTitle} pillars={copy.home.operationalPillars} />
  <CategoryDiscovery eyebrow={copy.home.categoryEyebrow} title={copy.home.categoryTitle} description={copy.home.categoryDescription} {categories} {categoryCounts} productLabel={copy.home.categoryProductLabel} {productsPath} />
  <FeaturedProducts eyebrow={copy.home.featuredProductsEyebrow} title={copy.home.featuredProductsTitle} products={products.filter((product) => product.featured)} locale={locale} />
  <FeaturedBrands eyebrow={copy.home.featuredBrandsEyebrow} title={copy.home.featuredBrandsTitle} {selectedBrand} {selectedBrandProducts} {remainingBrands} locale={locale} />
  <ServiceProof eyebrow={copy.home.serviceEyebrow} title={copy.home.serviceTitle} description={copy.home.serviceDescription} temperatureLabel={copy.home.serviceTemperatureLabel} pillars={copy.home.operationalPillars} editorial={featured.editorial} />
  <ChannelPathways eyebrow={copy.home.channelsEyebrow} title={copy.home.channelsTitle} {channels} />
  <FinalCta title={copy.home.finalCtaTitle} description={copy.home.finalCtaDescription} button={copy.home.finalCtaButton} label={copy.home.finalCtaLabel} href={contactPath} />
</SiteLayout>
