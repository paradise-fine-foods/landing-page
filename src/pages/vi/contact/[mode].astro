---
import EnquiryForm from '../../../components/forms/EnquiryForm.astro';
import Breadcrumbs from '../../../components/global/Breadcrumbs.astro';
import SiteLayout from '../../../layouts/SiteLayout.astro';
import { getGlobalSettings, getProducts } from '../../../lib/cms/queries';
import { localizedPath } from '../../../lib/i18n/routes';
import type { EnquiryMode } from '../../../lib/i18n/ui';
import { ui } from '../../../lib/i18n/ui';
import { getEnquiryModeCopy } from '../../../lib/enquiry/modes';

export function getStaticPaths() {
  return ['customer', 'supplier'].map((mode) => ({ params: { mode }, props: { mode } }));
}

const locale = 'vi';
const mode = Astro.props.mode as EnquiryMode;
const pathname = localizedPath(locale, mode === 'customer' ? 'customerContact' : 'supplierContact');
const alternatePath = localizedPath('en', mode === 'customer' ? 'customerContact' : 'supplierContact');
const [settings, products] = await Promise.all([getGlobalSettings(locale), getProducts(locale)]);
const copy = ui[locale];
const modeCopy = getEnquiryModeCopy(locale, mode);
---

<SiteLayout {locale} title={`${modeCopy.eyebrow} | ${settings.siteName}`} description={modeCopy.description} {pathname} {alternatePath} siteName={settings.siteName} demoNotice={settings.demoNotice}>
  <div class="contact-page container section-space">
    <Breadcrumbs label={copy.header.contact} items={[{ label: copy.header.home, href: localizedPath(locale, 'home') }, { label: copy.header.contact, href: localizedPath(locale, 'contact') }, { label: modeCopy.eyebrow }]} />
    <EnquiryForm {locale} {products} {copy} {mode} />
  </div>
</SiteLayout>
