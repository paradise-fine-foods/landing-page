---
import BrandCard from '../../../components/brands/BrandCard.astro';
import Breadcrumbs from '../../../components/global/Breadcrumbs.astro';
import SiteLayout from '../../../layouts/SiteLayout.astro';
import { getBrands } from '../../../lib/cms/queries';
import { localizedPath } from '../../../lib/i18n/routes';
import { ui } from '../../../lib/i18n/ui';

const locale = 'vi';
const pathname = localizedPath(locale, 'brands');
const alternatePath = localizedPath('en', 'brands');
const brands = await getBrands(locale);
const copy = ui[locale];
---

<SiteLayout {locale} title={`${copy.brand.title} | ${copy.siteName}`} description={copy.brand.description} {pathname} {alternatePath} siteName={copy.siteName} demoNotice={copy.demoNotice}>
  <div class="brands-page container section-space">
    <Breadcrumbs label={copy.brand.breadcrumb} items={[{ label: copy.header.home, href: localizedPath(locale, 'home') }, { label: copy.header.brands }]} />
    <header class="brands-page__intro">
      <p>{copy.brand.eyebrow}</p>
      <h1>{copy.brand.title}</h1>
      <p>{copy.brand.description}</p>
    </header>
    <section aria-label={copy.brand.title} class="brands-page__grid">
      {brands.map((brand, index) => <BrandCard {brand} {locale} index={index + 1} headingLevel="h2" />)}
    </section>
  </div>
</SiteLayout>

<style>
  .brands-page { min-inline-size: 0; }
  .brands-page__intro { display: grid; gap: var(--space-5); grid-template-columns: minmax(9rem, 1fr) minmax(0, 3fr); padding-block: var(--space-6) var(--space-8); }
  .brands-page__intro > p:first-child { color: var(--color-deep-herb); font-size: var(--text-xs); font-weight: 700; letter-spacing: var(--tracking-label); text-transform: uppercase; }
  .brands-page__intro h1 { font-size: var(--text-hero); max-inline-size: 13ch; }
  .brands-page__intro > p:last-child { font-size: var(--text-lg); grid-column: 2; max-inline-size: var(--measure); }
  .brands-page__grid { display: grid; }
  @media (max-width: 42rem) { .brands-page__intro { grid-template-columns: minmax(0, 1fr); } .brands-page__intro > p:last-child { grid-column: auto; } }
</style>
