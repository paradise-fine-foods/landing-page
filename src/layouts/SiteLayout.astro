---
import '@fontsource/newsreader/500.css';
import '@fontsource/nunito/400.css';
import '@fontsource/nunito/500.css';
import '@fontsource/nunito/600.css';
import '../styles/tokens.css';
import '../styles/typography.css';
import '../styles/global.css';
import { ui } from '../lib/i18n/ui';
import { localizedPath } from '../lib/i18n/routes';
import type { Locale } from '../lib/i18n/types';
import { buildMeta } from '../lib/seo/meta';
import Header from '../components/global/Header.astro';
import Footer from '../components/global/Footer.astro';
import FloatingFormRail from '../components/global/FloatingFormRail.astro';
import paradiseLogo from '../assets/brand/paradise-fine-foods-logo.png';

interface Props {
  locale: Locale;
  title: string;
  description: string;
  pathname: string;
  alternatePath?: string;
  image?: string;
  siteName: string;
  preloadImages?: Array<{ href: string; media?: string }>;
}

const { locale, title, description, pathname, alternatePath, image, siteName, preloadImages = [] } = Astro.props;
const socialImage = image ?? paradiseLogo.src;
const meta = buildMeta({
  site: Astro.site ?? 'https://paradisefinefoods.com',
  locale,
  title,
  description,
  pathname,
  alternatePath,
  image: socialImage,
});
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <title>{meta.title}</title>
    <meta name="description" content={meta.description} />
    <link rel="canonical" href={meta.canonical} />
    {preloadImages.map(({ href, media }) => (
      <link rel="preload" as="image" href={href} media={media} fetchpriority="high" />
    ))}
    {meta.alternates.map(({ locale: alternateLocale, href }) => (
      <link rel="alternate" hreflang={alternateLocale} href={href} />
    ))}
    <meta property="og:type" content={meta.openGraph.type} />
    <meta property="og:locale" content={meta.openGraph.locale} />
    <meta property="og:title" content={meta.openGraph.title} />
    <meta property="og:description" content={meta.openGraph.description} />
    <meta property="og:url" content={meta.openGraph.url} />
    {meta.openGraph.image && <meta property="og:image" content={meta.openGraph.image} />}
  </head>
  <body>
    <a class="skip-link" href="#main-content">{ui[locale].skipToContent}</a>
    <Header {locale} {siteName} currentPath={pathname} alternatePath={alternatePath ?? `/${locale}/`} />
    <main id="main-content">
      <slot />
    </main>
    <Footer {locale} {siteName} />
    <FloatingFormRail locale={locale} contactPath={localizedPath(locale, 'contact')} customerPath={localizedPath(locale, 'customerContact')} supplierPath={localizedPath(locale, 'supplierContact')} copy={ui[locale].floatingRail} />
  </body>
</html>
